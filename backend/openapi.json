{
  "openapi": "3.0.0",
  "info": {
    "title": "WHMS Backend API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:4000"
    }
  ],
  "components": {
    "schemas": {
      "UserBase": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "role": {
            "type": "string"
          },
          "emailVerified": {
            "type": "boolean"
          }
        },
        "required": [
          "id",
          "email",
          "role"
        ]
      },
      "RegisterResponse": {
        "type": "object",
        "properties": {
          "user": {
            "$ref": "#/components/schemas/UserBase"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "user"
        ]
      },
      "RateLimitResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "number",
            "enum": [
              429
            ]
          },
          "message": {
            "type": "string"
          },
          "retryAfter": {
            "type": "number"
          }
        },
        "required": [
          "status",
          "message"
        ]
      },
      "RegisterInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 8
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "Session": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "userId": {
            "type": "string"
          },
          "token": {
            "type": "string"
          },
          "ip": {
            "type": "string"
          },
          "userAgent": {
            "type": "string"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          },
          "isImpersonation": {
            "type": "boolean"
          },
          "impersonatorId": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "userId",
          "token",
          "expiresAt"
        ]
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "user": {
            "$ref": "#/components/schemas/UserBase"
          },
          "session": {
            "$ref": "#/components/schemas/Session"
          }
        },
        "required": [
          "accessToken",
          "refreshToken",
          "user"
        ]
      },
      "LoginInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string",
            "minLength": 6
          },
          "role": {
            "type": "string"
          }
        },
        "required": [
          "email",
          "password"
        ]
      },
      "RefreshInput": {
        "type": "object",
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        }
      },
      "GenericSuccess": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "success"
        ]
      },
      "LogoutInput": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string"
          }
        }
      },
      "EmailSendInput": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "required": [
          "email"
        ]
      },
      "EmailVerifyResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "message": {
            "type": "string"
          }
        },
        "required": [
          "success"
        ]
      },
      "ImpersonationStartResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "accessToken": {
            "type": "string",
            "example": "access_token_here"
          },
          "refreshToken": {
            "type": "string",
            "example": "refresh_token_here"
          },
          "sessionId": {
            "type": "string",
            "example": "sess_123"
          },
          "targetUser": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string",
                "example": "user_567"
              },
              "email": {
                "type": "string",
                "format": "email",
                "example": "client@example.com"
              }
            },
            "required": [
              "id",
              "email"
            ]
          }
        },
        "required": [
          "success",
          "accessToken",
          "refreshToken",
          "sessionId",
          "targetUser"
        ]
      },
      "ImpersonationStartInput": {
        "type": "object",
        "properties": {
          "targetUserId": {
            "type": "string",
            "example": "user_567"
          },
          "reason": {
            "type": "string",
            "example": "Customer support debugging"
          }
        },
        "required": [
          "targetUserId"
        ]
      },
      "ImpersonationStopResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "ImpersonationStopInput": {
        "type": "object",
        "properties": {
          "sessionId": {
            "type": "string",
            "example": "sess_123"
          }
        },
        "required": [
          "sessionId"
        ]
      },
      "ImpersonationSession": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "sess_abc123"
          },
          "userId": {
            "type": "string",
            "example": "user_123"
          },
          "token": {
            "type": "string",
            "example": "refresh_token_here"
          },
          "userAgent": {
            "type": "string",
            "nullable": true,
            "example": "Mozilla/5.0"
          },
          "ip": {
            "type": "string",
            "nullable": true,
            "example": "192.168.1.1"
          },
          "expiresAt": {
            "type": "string",
            "example": "2025-01-01T00:00:00.000Z"
          },
          "isImpersonation": {
            "type": "boolean"
          },
          "impersonatorId": {
            "type": "string",
            "nullable": true,
            "example": "admin_899"
          },
          "impersonationReason": {
            "type": "string",
            "nullable": true,
            "example": "Debug issue"
          },
          "createdAt": {
            "type": "string",
            "example": "2025-01-01T00:00:00.000Z"
          },
          "updatedAt": {
            "type": "string",
            "example": "2025-01-01T00:00:00.000Z"
          }
        },
        "required": [
          "id",
          "userId",
          "token",
          "userAgent",
          "ip",
          "expiresAt",
          "isImpersonation",
          "impersonatorId",
          "impersonationReason",
          "createdAt",
          "updatedAt"
        ]
      },
      "ImpersonationListResponse": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ImpersonationSession"
            }
          }
        },
        "required": [
          "items"
        ]
      },
      "ImpersonationStatus": {
        "type": "object",
        "properties": {
          "isImpersonation": {
            "type": "boolean"
          },
          "impersonatorId": {
            "type": "string"
          }
        },
        "required": [
          "isImpersonation"
        ]
      },
      "IpRule": {
        "type": "object",
        "properties": {
          "id": {
            "type": "number"
          },
          "pattern": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "ALLOW",
              "DENY"
            ]
          },
          "description": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string"
          },
          "updatedAt": {
            "type": "string"
          }
        },
        "required": [
          "id",
          "pattern",
          "type",
          "active",
          "createdAt"
        ]
      },
      "IpRuleListResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "rules": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/IpRule"
            }
          }
        },
        "required": [
          "success",
          "rules"
        ]
      },
      "IpRuleCreateResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "rule": {
            "$ref": "#/components/schemas/IpRule"
          }
        },
        "required": [
          "success",
          "rule"
        ]
      },
      "IpRuleCreateInput": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "ALLOW",
              "DENY"
            ]
          },
          "description": {
            "type": "string"
          }
        },
        "required": [
          "pattern",
          "type"
        ]
      },
      "IpRuleUpdateResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "rule": {
            "$ref": "#/components/schemas/IpRule"
          }
        },
        "required": [
          "success",
          "rule"
        ]
      },
      "IpRuleUpdateInput": {
        "type": "object",
        "properties": {
          "pattern": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": [
              "ALLOW",
              "DENY"
            ]
          },
          "description": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "AdminUserSummary": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "example": "user_123"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "emailVerified": {
            "type": "boolean"
          },
          "disabled": {
            "type": "boolean"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "createdAt": {
            "type": "string"
          },
          "lastLogin": {
            "type": "string",
            "nullable": true
          },
          "profileSummary": {
            "type": "object",
            "properties": {
              "client": {
                "type": "boolean"
              },
              "admin": {
                "type": "boolean"
              },
              "reseller": {
                "type": "boolean"
              },
              "developer": {
                "type": "boolean"
              }
            },
            "required": [
              "client",
              "admin",
              "reseller",
              "developer"
            ]
          }
        },
        "required": [
          "id",
          "email",
          "disabled",
          "createdAt",
          "profileSummary"
        ]
      },
      "AdminUserListResponse": {
        "type": "object",
        "properties": {
          "total": {
            "type": "number"
          },
          "page": {
            "type": "number"
          },
          "limit": {
            "type": "number"
          },
          "users": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AdminUserSummary"
            }
          }
        },
        "required": [
          "total",
          "page",
          "limit",
          "users"
        ]
      },
      "AdminUserFullResponse": {
        "type": "object",
        "properties": {
          "user": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              },
              "emailVerified": {
                "type": "boolean"
              },
              "disabled": {
                "type": "boolean"
              },
              "roles": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "role": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "string"
                        },
                        "permissions": {
                          "type": "array",
                          "items": {
                            "type": "object",
                            "properties": {
                              "permission": {
                                "type": "object",
                                "properties": {
                                  "name": {
                                    "type": "string"
                                  }
                                },
                                "required": [
                                  "name"
                                ]
                              }
                            },
                            "required": [
                              "permission"
                            ]
                          }
                        }
                      },
                      "required": [
                        "name",
                        "permissions"
                      ]
                    }
                  },
                  "required": [
                    "role"
                  ]
                }
              },
              "clientProfile": {
                "nullable": true
              },
              "adminProfile": {
                "nullable": true
              },
              "resellerProfile": {
                "nullable": true
              },
              "developerProfile": {
                "nullable": true
              },
              "sessions": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "userId": {
                      "type": "string"
                    },
                    "token": {
                      "type": "string"
                    },
                    "ip": {
                      "type": "string",
                      "nullable": true
                    },
                    "userAgent": {
                      "type": "string",
                      "nullable": true
                    },
                    "expiresAt": {
                      "type": "string"
                    },
                    "isImpersonation": {
                      "type": "boolean"
                    },
                    "createdAt": {
                      "type": "string"
                    },
                    "updatedAt": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "userId",
                    "token",
                    "ip",
                    "userAgent",
                    "expiresAt"
                  ]
                }
              }
            },
            "required": [
              "id",
              "email",
              "roles",
              "sessions"
            ]
          }
        },
        "required": [
          "user"
        ]
      },
      "AdminUserUpdateRolesResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "required": [
          "success",
          "roles"
        ]
      },
      "AdminUserUpdateRolesInput": {
        "type": "object",
        "properties": {
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          }
        },
        "required": [
          "roles"
        ]
      },
      "AdminUserDeactivateResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "AdminUserDeactivateInput": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      },
      "AdminUserForceLogoutResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        },
        "required": [
          "success"
        ]
      },
      "AdminUserImpersonateResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "sessionId": {
            "type": "string"
          },
          "targetUser": {
            "type": "object",
            "properties": {
              "id": {
                "type": "string"
              },
              "email": {
                "type": "string",
                "format": "email"
              }
            },
            "required": [
              "id",
              "email"
            ]
          }
        },
        "required": [
          "success",
          "accessToken",
          "refreshToken",
          "sessionId",
          "targetUser"
        ]
      },
      "AdminUserImpersonateInput": {
        "type": "object",
        "properties": {
          "reason": {
            "type": "string"
          }
        }
      }
    },
    "parameters": {}
  },
  "security": [
    {
      "BearerAuth": []
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "summary": "Register a new user",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterInput"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "User created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "400": {
            "description": "Validation error"
          },
          "429": {
            "description": "Rate limit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "summary": "Login user (returns tokens)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login success",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid credentials"
          },
          "429": {
            "description": "Rate limit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "summary": "Refresh & rotate token",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Tokens rotated",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid refresh token"
          }
        }
      }
    },
    "/api/auth/logout": {
      "post": {
        "summary": "Logout and terminate session",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LogoutInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Logged out",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericSuccess"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/email/send": {
      "post": {
        "summary": "Send verification email",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/EmailSendInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Verification sent",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GenericSuccess"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RateLimitResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/email/verify": {
      "get": {
        "summary": "Verify email using token",
        "parameters": [
          {
            "schema": {
              "type": "string"
            },
            "required": true,
            "name": "token",
            "in": "query"
          }
        ],
        "responses": {
          "200": {
            "description": "Email verified",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/EmailVerifyResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid token"
          }
        }
      }
    },
    "/api/auth/impersonate/start": {
      "post": {
        "summary": "Start impersonation (admin only)",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImpersonationStartInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Impersonation started",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImpersonationStartResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/impersonate/stop": {
      "post": {
        "summary": "Stop impersonation",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImpersonationStopInput"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Stopped",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImpersonationStopResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/impersonate/list": {
      "get": {
        "summary": "List impersonation sessions",
        "responses": {
          "200": {
            "description": "List",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImpersonationListResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/auth/impersonation-status": {
      "get": {
        "summary": "Check impersonation status",
        "responses": {
          "200": {
            "description": "Status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImpersonationStatus"
                }
              }
            }
          }
        }
      }
    },
    "/api/ip-rules": {
      "get": {
        "summary": "List IP access rules",
        "responses": {
          "200": {
            "description": "Rules returned",
            "content": {
              "application/json": {
                "schema": {
