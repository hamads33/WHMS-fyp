<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{subject}}</title>
  <style>
    body { margin:0; padding:0; background:#f4f4f7; font-family:'Segoe UI',Arial,sans-serif; color:#333; }
    .wrapper { width:100%; background:#f4f4f7; padding:32px 0; }
    .container { max-width:600px; margin:0 auto; background:#ffffff; border-radius:8px; overflow:hidden; box-shadow:0 2px 8px rgba(0,0,0,.08); }
    .header { background:{{brand_color}}; padding:28px 40px; text-align:center; }
    .header img { max-height:48px; }
    .header h1 { color:#ffffff; margin:0; font-size:22px; font-weight:600; letter-spacing:.3px; }
    .body { padding:36px 40px; }
    .body p { font-size:15px; line-height:1.7; margin:0 0 16px; }
    .body h2 { font-size:18px; margin:0 0 16px; color:#222; }
    .btn { display:inline-block; background:{{brand_color}}; color:#ffffff !important; text-decoration:none; padding:13px 32px; border-radius:5px; font-size:15px; font-weight:600; margin:8px 0 16px; }
    .info-box { background:#f8f9fc; border-left:4px solid {{brand_color}}; border-radius:4px; padding:16px 20px; margin:20px 0; font-size:14px; line-height:1.6; }
    .info-box strong { display:block; margin-bottom:4px; color:#555; font-size:12px; text-transform:uppercase; letter-spacing:.5px; }
    table.details { width:100%; border-collapse:collapse; margin:20px 0; font-size:14px; }
    table.details th { background:#f0f2f5; text-align:left; padding:10px 14px; color:#555; font-weight:600; border-bottom:2px solid #e0e3ea; }
    table.details td { padding:10px 14px; border-bottom:1px solid #eef0f4; vertical-align:top; }
    table.details tr:last-child td { border-bottom:none; }
    .total-row td { font-weight:700; font-size:15px; background:#f8f9fc; }
    .divider { border:none; border-top:1px solid #eef0f4; margin:24px 0; }
    .alert-box { background:#fff3cd; border-left:4px solid #ffc107; border-radius:4px; padding:14px 18px; margin:20px 0; font-size:14px; }
    .alert-box.danger { background:#fde8e8; border-color:#e53e3e; }
    .alert-box.success { background:#e8f5e9; border-color:#38a169; }
    .footer { background:#f8f9fc; padding:20px 40px; text-align:center; font-size:12px; color:#888; border-top:1px solid #eef0f4; }
    .footer a { color:#888; }
    @media (max-width:620px) {
      .body, .header, .footer { padding-left:20px; padding-right:20px; }
      .btn { display:block; text-align:center; }
    }
  </style>
</head>
<body>
<div class="wrapper">
  <div class="container">
    <div class="header">
      {{#if brand_logo}}<img src="{{brand_logo}}" alt="{{company_name}}" /><br/>{{/if}}
      <h1>{{company_name}}</h1>
    </div>
    <div class="body">
      {{{content}}}
    </div>
    <div class="footer">
      {{#if footer_text}}<p>{{footer_text}}</p>{{/if}}
      <p>&copy; {{year}} {{company_name}}. All rights reserved.</p>
      <p>{{company_address}}</p>
    </div>
  </div>
</div>
</body>
</html>
