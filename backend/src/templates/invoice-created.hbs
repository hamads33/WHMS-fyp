<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Invoice #{{invoice_id}}</title>
<style>body{margin:0;padding:0;background:#f4f4f7;font-family:'Segoe UI',Arial,sans-serif;color:#333}.wrapper{width:100%;background:#f4f4f7;padding:32px 0}.container{max-width:600px;margin:0 auto;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.08)}.header{background:#4f46e5;padding:28px 40px;text-align:center}.header h1{color:#fff;margin:0;font-size:22px;font-weight:600}.body{padding:36px 40px}.body p{font-size:15px;line-height:1.7;margin:0 0 16px}.btn{display:inline-block;background:#4f46e5;color:#fff!important;text-decoration:none;padding:13px 32px;border-radius:5px;font-size:15px;font-weight:600;margin:8px 0 16px}table.details{width:100%;border-collapse:collapse;margin:20px 0;font-size:14px}table.details th{background:#f0f2f5;text-align:left;padding:10px 14px;color:#555;font-weight:600;border-bottom:2px solid #e0e3ea}table.details td{padding:10px 14px;border-bottom:1px solid #eef0f4;vertical-align:top}table.details tr:last-child td{border-bottom:none}.total-row td{font-weight:700;font-size:15px;background:#f8f9fc}.alert-box{background:#fff3cd;border-left:4px solid #ffc107;border-radius:4px;padding:14px 18px;margin:20px 0;font-size:14px}.footer{background:#f8f9fc;padding:20px 40px;text-align:center;font-size:12px;color:#888;border-top:1px solid #eef0f4}</style>
</head><body>
<div class="wrapper"><div class="container">
  <div class="header"><h1>{{company_name}}</h1></div>
  <div class="body">
    <h2 style="font-size:20px;margin:0 0 4px">Invoice #{{invoice_id}}</h2>
    <p style="color:#888;font-size:14px;margin:0 0 24px">Generated on {{invoice_date}}</p>
    <p>Hi {{client_name}},</p>
    <p>A new invoice has been generated for your account. Please review the details below and make payment before the due date.</p>
    <table class="details">
      <tr><th>Description</th><th style="text-align:right">Amount</th></tr>
      {{#each line_items}}
      <tr><td>{{this.description}}</td><td style="text-align:right">{{this.amount}}</td></tr>
      {{/each}}
      {{#if subtotal}}<tr><td style="color:#888">Subtotal</td><td style="text-align:right;color:#888">{{subtotal}}</td></tr>{{/if}}
      {{#if tax_amount}}<tr><td style="color:#888">Tax ({{tax_rate}}%)</td><td style="text-align:right;color:#888">{{tax_amount}}</td></tr>{{/if}}
      <tr class="total-row"><td>Total Due</td><td style="text-align:right">{{invoice_total}}</td></tr>
    </table>
    <div class="alert-box">📅 <strong>Due Date:</strong> {{due_date}}</div>
    <p style="text-align:center"><a href="{{invoice_url}}" class="btn">View &amp; Pay Invoice</a></p>
    <p>Regards,<br/><strong>{{company_name}} Billing Team</strong></p>
  </div>
  <div class="footer"><p>&copy; {{year}} {{company_name}}. All rights reserved.</p>{{#if footer_text}}<p>{{footer_text}}</p>{{/if}}</div>
</div></div>
</body></html>
