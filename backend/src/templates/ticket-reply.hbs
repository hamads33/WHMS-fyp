<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Reply to Ticket #{{ticket_id}}</title>
<style>body{margin:0;padding:0;background:#f4f4f7;font-family:'Segoe UI',Arial,sans-serif;color:#333}.wrapper{width:100%;background:#f4f4f7;padding:32px 0}.container{max-width:600px;margin:0 auto;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.08)}.header{background:#4f46e5;padding:28px 40px;text-align:center}.header h1{color:#fff;margin:0;font-size:22px;font-weight:600}.body{padding:36px 40px}.body p{font-size:15px;line-height:1.7;margin:0 0 16px}.btn{display:inline-block;background:#4f46e5;color:#fff!important;text-decoration:none;padding:13px 32px;border-radius:5px;font-size:15px;font-weight:600;margin:8px 0 16px}.info-box{background:#f8f9fc;border-left:4px solid #4f46e5;border-radius:4px;padding:14px 18px;margin:16px 0;font-size:14px;line-height:1.7}.reply-box{background:#fff;border:1px solid #e0e3ea;border-radius:6px;padding:16px 20px;margin:20px 0;font-size:14px;line-height:1.7}.reply-meta{font-size:12px;color:#888;margin-bottom:8px}.footer{background:#f8f9fc;padding:20px 40px;text-align:center;font-size:12px;color:#888;border-top:1px solid #eef0f4}</style>
</head><body>
<div class="wrapper"><div class="container">
  <div class="header"><h1>{{company_name}}</h1></div>
  <div class="body">
    <h2 style="font-size:20px;margin:0 0 16px">New Reply on Ticket #{{ticket_id}}</h2>
    <p>Hi {{client_name}},</p>
    <p>There is a new reply on your support ticket.</p>
    <div class="info-box">
      Subject: <strong>{{ticket_subject}}</strong><br/>
      Status: {{ticket_status}}
    </div>
    <div class="reply-box">
      <div class="reply-meta">{{reply_author}} replied on {{reply_date}}</div>
      {{{reply_message}}}
    </div>
    <p style="text-align:center"><a href="{{ticket_url}}" class="btn">View &amp; Reply</a></p>
    <p>Regards,<br/><strong>{{company_name}} Support Team</strong></p>
  </div>
  <div class="footer"><p>&copy; {{year}} {{company_name}}. All rights reserved.</p>{{#if footer_text}}<p>{{footer_text}}</p>{{/if}}</div>
</div></div>
</body></html>
