<!DOCTYPE html>
<html lang="en"><head><meta charset="UTF-8"/><meta name="viewport" content="width=device-width,initial-scale=1.0"/><title>Service Activated</title>
<style>body{margin:0;padding:0;background:#f4f4f7;font-family:'Segoe UI',Arial,sans-serif;color:#333}.wrapper{width:100%;background:#f4f4f7;padding:32px 0}.container{max-width:600px;margin:0 auto;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,.08)}.header{background:#16a34a;padding:28px 40px;text-align:center}.header h1{color:#fff;margin:0;font-size:22px;font-weight:600}.body{padding:36px 40px}.body p{font-size:15px;line-height:1.7;margin:0 0 16px}.btn{display:inline-block;background:#4f46e5;color:#fff!important;text-decoration:none;padding:13px 32px;border-radius:5px;font-size:15px;font-weight:600;margin:8px 0 16px}.info-box{background:#f8f9fc;border-left:4px solid #16a34a;border-radius:4px;padding:16px 20px;margin:20px 0;font-size:14px;line-height:1.9}.cred-box{background:#1e1b4b;color:#e0e7ff;border-radius:6px;padding:16px 20px;margin:20px 0;font-family:monospace;font-size:13px;line-height:1.9}.footer{background:#f8f9fc;padding:20px 40px;text-align:center;font-size:12px;color:#888;border-top:1px solid #eef0f4}</style>
</head><body>
<div class="wrapper"><div class="container">
  <div class="header"><h1>{{company_name}}</h1></div>
  <div class="body">
    <h2 style="font-size:20px;margin:0 0 16px">🚀 Your Service is Active!</h2>
    <p>Hi {{client_name}},</p>
    <p>Great news! Your <strong>{{service_name}}</strong> service has been successfully activated.</p>
    <div class="info-box">
      <strong>Service Details</strong><br/>
      Service: {{service_name}}<br/>
      Plan: {{service_plan}}<br/>
      Activated On: {{activation_date}}<br/>
      {{#if next_due_date}}Next Due: {{next_due_date}}{{/if}}
    </div>
    {{#if has_credentials}}
    <div class="cred-box">
      <strong style="color:#a5b4fc">Login Credentials</strong><br/>
      {{#if control_panel_url}}Control Panel: {{control_panel_url}}<br/>{{/if}}
      {{#if username}}Username: {{username}}<br/>{{/if}}
      {{#if password}}Password: {{password}}<br/>{{/if}}
      {{#if server_ip}}Server IP: {{server_ip}}{{/if}}
    </div>
    {{/if}}
    <p style="text-align:center"><a href="{{portal_url}}" class="btn">Manage Service</a></p>
    <p>If you need help getting started, visit our <a href="{{docs_url}}">documentation</a> or contact support at <a href="mailto:{{support_email}}">{{support_email}}</a>.</p>
    <p>Regards,<br/><strong>{{company_name}} Team</strong></p>
  </div>
  <div class="footer"><p>&copy; {{year}} {{company_name}}. All rights reserved.</p>{{#if footer_text}}<p>{{footer_text}}</p>{{/if}}</div>
</div></div>
</body></html>
