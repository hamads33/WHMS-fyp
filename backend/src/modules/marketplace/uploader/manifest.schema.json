{
  "$id": "https://example.com/plugin-manifest.schema.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Plugin Manifest",
  "type": "object",
  "required": ["name", "version", "actions", "type"],
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "type": {
      "type": "string",
      "enum": ["action", "ui", "automation", "integration"]
    },
    "description": {
      "type": "string"
    },
    "author": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "actions": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "properties": {
          "description": { "type": "string" },
          "paramsSchema": { "type": "object" },
          "permissions": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["description"]
      }
    },
    "ui": {
      "type": "object",
      "properties": {
        "entry": { "type": "string" },
        "origin": { "type": "string", "format": "uri" }
      }
    },
    "metadata": {
      "type": "object"
    }
  },
  "additionalProperties": false
}
