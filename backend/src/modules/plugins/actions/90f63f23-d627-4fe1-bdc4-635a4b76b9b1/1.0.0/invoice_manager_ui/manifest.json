{
  "id": "invoice_manager_ui",
  "name": "Invoice Manager UI",
  "version": "1.0.0",
  "description": "Advanced invoice manager UI plugin with admin & client pages.",
  "source": "user",
  "uiEnabled": true,
  "menuLabel": "Invoice Manager",
  "rolesAllowed": ["admin", "client"],

  "pages": [
    {
      "role": "admin",
      "path": "/admin/invoices",
      "component": "AdminDashboard"
    },
    {
      "role": "client",
      "path": "/client/invoices",
      "component": "ClientInvoices"
    }
  ],

  "widgets": [
    {
      "id": "total_revenue",
      "name": "Total Revenue Widget",
      "component": "TotalRevenueWidget",
      "role": "admin"
    }
  ],

  "build": {
    "outputDir": "dist",
    "entry": "src/main.jsx"
  }
}
