      "fnName": "wait",
      "description": "Async wait demo"
    }
  },

  "hooks": {
    "system.demo": {
      "action": "hello"
    }
  },

  "ui": {
    "menu": {
      "title": "Demo Plugin",
      "path": "/plugins/demo-test-plugin"
    }
  }
}
