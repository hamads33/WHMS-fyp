/////////////////////////////////////////
// AUDIT
/////////////////////////////////////////
model Audit {
  id        Int      @id @default(autoincrement())
  actor     String?
  action    String
  payload   Json?
  createdAt DateTime @default(now())
}



model StorageConfig {
  id           Int       @id @default(autoincrement())
  name         String
  provider     String    // ftp | ftps | sftp | local | s3 ...
  config       Json      // encrypted or plain JSON (we'll store encrypted blob if desired)
  createdById  Int?      // optional user id
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  backups      Backup[]
}

model Backup {
  id             Int       @id @default(autoincrement())
  name           String
  type           String    // db | files | full
  storageConfig  StorageConfig? @relation(fields: [storageConfigId], references: [id])
  storageConfigId Int?
  filePath       String?   // remote path or local path
  sizeBytes      Int?
  status         String    @default("pending") // pending | running | success | failed
  errorMessage   String?
  startedAt      DateTime?
  finishedAt     DateTime?
  retentionDays  Int       @default(30)
  createdById    Int?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}
//////////////////////////////////////////////////////////////////

model AutomationProfile {
  id          Int           @id @default(autoincrement())
  name        String
  description String?
  cron        String
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  tasks       AutomationTask[]
  runs        AutomationRun[]
}

model AutomationTask {
  id         Int      @id @default(autoincrement())
  profileId  Int
  actionType String   // e.g. builtin:test_action
  actionMeta Json?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  runs    AutomationRun[]
}

model AutomationRun {
  id           Int       @id @default(autoincrement())
  profileId    Int
  taskId       Int?
  status       String    // pending|running|success|failed
  result       Json?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  task    AutomationTask?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([taskId])
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  source     String   // e.g. "automation", "auth"
  action     String   // e.g. "profile.create", "task.run"
  actor      String?  // username or system
  meta       Json?
  level      String   // INFO, WARN, ERROR
  createdAt  DateTime @default(now())
}