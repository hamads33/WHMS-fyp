////////////////////////////////////////////////////////////
// DATABASE + GENERATOR
////////////////////////////////////////////////////////////

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

////////////////////////////////////////////////////////////
// USERS (Single Identity for all roles)
////////////////////////////////////////////////////////////

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  emailVerified Boolean @default(false)
disabled      Boolean  @default(false)
  mfaEnabled     Boolean  @default(false)
  mfaSecret      String?
  mfaBackupCodes String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RBAC
  roles UserRole[]

  // Auth & Security
  sessions               Session[]
  apiKeys                ApiKey[]
  loginLogs              LoginLog[]
  trustedDevices         TrustedDevice[]
  emailTokens            EmailToken[]
  auditLogs              AuditLog[]
  domains                Domain[]
  orders                 Order[]
  // Impersonation
  impersonationsStarted  Impersonation[] @relation("Impersonator")
  impersonationsReceived Impersonation[] @relation("Impersonated")

  // Portal Profiles
  clientProfile    ClientProfile?
  adminProfile     AdminProfile?
  resellerProfile  ResellerProfile?
  developerProfile DeveloperProfile?

  // Marketplace
  marketplaceReviews     MarketplaceReview[]
  marketplaceSubmissions MarketplaceSubmission[]
  marketplacePurchases   MarketplacePurchase[]

  // Tickets
  tickets Ticket[]

  // Legacy
  refreshTokens RefreshToken[]
}

////////////////////////////////////////////////////////////
// ROLE SYSTEM (RBAC)
////////////////////////////////////////////////////////////

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  rolePerms   RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@unique([userId, roleId])
}

////////////////////////////////////////////////////////////
// SESSIONS
////////////////////////////////////////////////////////////

model Session {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  token     String   @unique
  userAgent String?
  ip        String?
  deviceHash     String?      // 🔐 hashed device fingerprint
  country        String?      // 🌍 geo-IP (country only)
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
  expiresAt DateTime

 lastActivity DateTime @default(now())
  isImpersonation     Boolean @default(false)
  impersonatorId      String?
  impersonationReason String?
}

////////////////////////////////////////////////////////////
// TRUSTED DEVICES
////////////////////////////////////////////////////////////

model TrustedDevice {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  deviceId   String   @unique
  userAgent  String?
  ip         String?
  name       String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @updatedAt
  expiresAt  DateTime
  revoked    Boolean  @default(false)
}

////////////////////////////////////////////////////////////
// API KEYS
////////////////////////////////////////////////////////////

model ApiKey {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  name      String
  keyHash   String
  createdAt DateTime  @default(now())
  revoked   Boolean   @default(false)
  expiresAt DateTime?

  scopes ApiKeyScope[]
}

model ApiKeyScope {
  id       String @id @default(uuid())
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id])
  apiKeyId String
  scope    String
}

////////////////////////////////////////////////////////////
// LOGIN LOGS
////////////////////////////////////////////////////////////

model LoginLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  userEmail String?
  success   Boolean
  ip        String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())
}

////////////////////////////////////////////////////////////
// USER PROFILES
////////////////////////////////////////////////////////////

model ClientProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  company String?
  phone   String?
  address String?
  country String?
  city    String?
  postal  String?
}

model AdminProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  department      String?
  staffTitle      String?
  restrictionJson Json?
}

model ResellerProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  resellerCode String  @unique
  company      String?
  phone        String?
  address      String?
}

model DeveloperProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  displayName String?
  website     String?
  github      String?

  storeName       String?
  payoutsEmail    String?
  stripeAccountId String?
  publicKeyPem    String?
  marketplaceMeta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products MarketplaceProduct[] @relation("dev_products")
}

////////////////////////////////////////////////////////////
// IMPERSONATION RECORDS
////////////////////////////////////////////////////////////

model Impersonation {
  id             String @id @default(uuid())
  adminId        String
  admin          User?  @relation("Impersonator", fields: [adminId], references: [id])
  impersonatedId String
  impersonated   User?  @relation("Impersonated", fields: [impersonatedId], references: [id])

  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  sessionToken String    @unique
  reason       String?
}

////////////////////////////////////////////////////////////
// EMAIL TOKENS
////////////////////////////////////////////////////////////

model EmailToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tokenHash String
  type      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
}

////////////////////////////////////////////////////////////
// AUDIT LOGS
////////////////////////////////////////////////////////////

model AuditLog {
  id        Int      @id @default(autoincrement())
  source    String
  action    String
  actor     String
  level     String   @default("INFO")
  meta      Json?
  userId    String?
  ip        String?
  userAgent String?
  entity    String?
  entityId  String?
  data      Json?
  profileId Int?
profile   AutomationProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
@@index([profileId])
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

////////////////////////////////////////////////////////////
// WEBHOOKS
////////////////////////////////////////////////////////////

model Webhook {
  id        String   @id @default(cuid())
  name      String   @unique
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs WebhookLog[]
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  status     String
  httpStatus Int?
  attempts   Int      @default(0)
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id])
}

////////////////////////////////////////////////////////////
// REFRESH TOKENS
////////////////////////////////////////////////////////////

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

////////////////////////////////////////////////////////////
// TICKETS
////////////////////////////////////////////////////////////

model Ticket {
  id        Int      @id @default(autoincrement())
  clientId  String
  subject   String
  message   String
  priority  String
  status    String   @default("open")
  createdAt DateTime @default(now())

  client User @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

////////////////////////////////////////////////////////////
// EMAIL SYSTEM
////////////////////////////////////////////////////////////

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  subject   String
  bodyHtml  String
  bodyText  String?
  language  String   @default("en")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs EmailJob[]
}

model EmailJob {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   Int?
  templateName String?
  toEmail      String
  toName       String?
  payload      Json?
  status       String   @default("queued")
  attempts     Int      @default(0)
  lastError    String?
  priority     String   @default("normal")
  provider     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@index([status])
}

model EmailEvent {
  id         Int      @id @default(autoincrement())
  jobId      String?
  eventType  String
  providerId String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([jobId])
}

////////////////////////////////////////////////////////////
// DOMAINS
////////////////////////////////////////////////////////////

enum DomainStatus {
  pending_registration
  active
  expired
  grace
  redemption
  transfer_pending
  transfer_failed
  transferred_out
  cancelled
}

enum DomainContactType {
  registrant
  admin
  tech
  billing
}

enum DomainTransferStatus {
  pending
  approved
  rejected
  completed
}

model Domain {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Ownership
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Registrar
  registrar        String?
  providerConfigId Int?
  providerConfig   ProviderConfig? @relation(fields: [providerConfigId], references: [id])

  // Lifecycle
  status     DomainStatus @default(pending_registration)
  expiryDate DateTime?
  autoRenew  Boolean      @default(true)

  // Billing snapshot (price locked at time of invoice)
  registrationPrice Int?
  renewalPrice      Int?
  currency          String @default("USD")

  // DNS
  nameservers String[] @default([])

  // Extra registrar / TLD specific fields
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  dnsRecords    DNSRecord[]
  contacts      DomainContact[]
  transfers     DomainTransfer[]
  registrarLogs DomainRegistrarCommand[]
  logs          DomainLog[]

  @@index([ownerId])
  @@index([status])
  @@index([expiryDate])
}

model DomainContact {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  type    DomainContactType
  name    String
  email   String
  phone   String
  country String

  createdAt DateTime @default(now())

  @@unique([domainId, type])
}

model DomainTransfer {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  authCode String
  status   DomainTransferStatus @default(pending)

  requestedAt DateTime  @default(now())
  completedAt DateTime?

  providerResponse Json?

  @@index([status])
}

model DNSRecord {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  type  String // A, AAAA, MX, TXT, CNAME
  name  String
  value String
  ttl   Int    @default(3600)

  providerRecordId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domainId])
}

model DomainRegistrarCommand {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  action   String // register, renew, transfer, update_ns
  request  Json?
  response Json?
  success  Boolean

  createdAt DateTime @default(now())

  @@index([domainId])
  @@index([action])
}

model DomainLog {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  action  String
  message String?
  meta    Json?

  createdAt DateTime @default(now())

  @@index([domainId])
}

model TldPricing {
  id           Int      @id @default(autoincrement())
  tld          String   @unique
  registration Decimal  @db.Decimal(10, 2)
  renewal      Decimal  @db.Decimal(10, 2)
  transfer     Decimal  @db.Decimal(10, 2)
  provider     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

////////////////////////////////////////////////////////////
// PROVIDER CONFIG
////////////////////////////////////////////////////////////

model ProviderConfig {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  key       String?
  secret    String?
  endpoint  String?
  active    Boolean  @default(true)
  domains   Domain[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StorageConfig {
  id          Int      @id @default(autoincrement())
  name        String
  provider    String
  config      Json
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // FIX: Added indexes for better query performance
  @@index([createdById])
  @@index([provider])
}

////////////////////////////////////////////////////////////
// BACKUP SYSTEM
////////////////////////////////////////////////////////////

model Backup {
  id              String    @id @default(cuid())
  name            String
  type            String
  storageConfigId Int?
  filePath        String?
  sizeBytes       BigInt?
  status          String
  retentionDays   Int?
  createdById     String
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?
  deleted         Boolean   @default(false)
  errorMessage    String?

  versions BackupVersion[]
  stepLogs BackupStepLog[]

  // FIX: Added composite index for retention policy queries
  // This dramatically improves performance when finding expired backups
  @@index([deleted, status, finishedAt])
  @@index([createdById])
  @@index([status])
}


model BackupVersion {
  id        String   @id @default(uuid())
  backupId  String
  version   Int      @default(1)
  filePath  String
  sizeBytes BigInt?
  createdAt DateTime @default(now())

  backup Backup @relation(fields: [backupId], references: [id])

  // FIX: Added indexes for version queries
  @@index([backupId])
  @@index([createdAt])
}
model BackupStepLog {
  id        String   @id @default(uuid())
  backupId  String
  step      String
  meta      Json?
  status    String   @default("started")
  message   String?
  createdAt DateTime @default(now())

  backup Backup @relation(fields: [backupId], references: [id])

  // FIX: Added indexes for log queries
  @@index([backupId])
  @@index([status])
  @@index([createdAt])
}

////////////////////////////////////////////////////////////
// TLD PRICING
////////////////////////////////////////////////////////////

model Tld {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  registerPrice Int?
  renewPrice    Int?
  transferPrice Int?
  markupPercent Int?
  providerData  Json?
  lastSynced    DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

////////////////////////////////////////////////////////////
// PLUGIN REGISTRY
////////////////////////////////////////////////////////////

model Plugin {
  id           String   @id @default(uuid())
  name         String
  version      String
  folder       String
  type         String?  @default("ui")
  enabled      Boolean  @default(true)
  installedAt  DateTime @default(now())
  configSchema Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  settings PluginSetting[]
}

model PluginSetting {
  id        Int      @id @default(autoincrement())
  pluginId  String
  key       String
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plugin Plugin @relation(fields: [pluginId], references: [id])

  @@unique([pluginId, key])
  @@index([pluginId])
}

////////////////////////////////////////////////////////////
// AUTOMATION SYSTEM
///////////////////////////////////////////////////////////


// ============================================================
// ENUMS - Define all enums first
// ============================================================

enum AutomationRunStatus {
  pending
  running
  success
  failed
}

enum WorkflowRunStatus {
  pending
  running
  success
  failed
  cancelled
  paused
}

enum WorkflowTaskStatus {
  pending
  running
  success
  failed
  skipped
  waiting_retry
  waiting_condition
}


// ============================================================
// AUTOMATION SYSTEM (Core)
// ============================================================

model AutomationProfile {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String? @db.Text
  cron        String? @db.VarChar(100)
  enabled     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tasks       AutomationTask[]
  runs        AutomationRun[]
  auditLogs   AuditLog[]
  workflows   AutomationWorkflow[]
  workflowRuns WorkflowRun[]

  // Indexes
  @@unique([name])
  @@index([enabled])
  @@index([cron])
}

model AutomationTask {
  id         Int     @id @default(autoincrement())
  profileId  Int
  actionType String  @db.VarChar(100)
  actionMeta Json?
  order      Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  runs    AutomationRun[]

  // Indexes
  @@index([profileId])
  @@index([order])
}

model AutomationRun {
  id           Int                   @id @default(autoincrement())
  profileId    Int
  taskId       Int?
  status       AutomationRunStatus
  result       Json?
  errorMessage String?               @db.Text

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime               @default(now())

  // Relations
  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  task    AutomationTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([profileId])
  @@index([taskId])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// WORKFLOW SYSTEM (Enterprise)
// ============================================================

model AutomationWorkflow {
  id          Int     @id @default(autoincrement())
  profileId   Int
  name        String  @db.VarChar(255)
  description String? @db.Text

  // Workflow definition (complete JSON structure)
  definition Json

  enabled    Boolean @default(true)
  version    Int     @default(1)
  isDraft    Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  runs    WorkflowRun[]

  // Indexes
  @@index([profileId])
  @@index([enabled])
  @@index([createdAt])
}

model WorkflowRun {
  id            Int               @id @default(autoincrement())
  workflowId    Int
  profileId     Int
  status        WorkflowRunStatus @default(pending)

  startedAt    DateTime?
  finishedAt   DateTime?
  totalDuration Int? // milliseconds

  taskCount    Int @default(0)
  successCount Int @default(0)
  failureCount Int @default(0)
  skippedCount Int @default(0)

  failedTaskId String? // Which task failed
  errorMessage String? @db.Text
  errorStack   String? @db.Text

  triggeredBy String @default("manual") // "schedule", "manual", "webhook"

  input  Json?
  output Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  workflow AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  profile  AutomationProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  taskRuns WorkflowTaskRun[]

  // Indexes
  @@index([workflowId])
  @@index([profileId])
  @@index([status])
  @@index([createdAt])
}

model WorkflowTaskRun {
  id       Int                 @id @default(autoincrement())
  runId    Int
  taskId   String // Task ID from workflow definition
  status   WorkflowTaskStatus  @default(pending)

  startedAt  DateTime?
  finishedAt DateTime?
  duration   Int? // milliseconds

  output        Json?
  errorMessage  String? @db.Text
  errorStack    String? @db.Text

  retryCount  Int       @default(0)
  maxRetries  Int       @default(0)
  nextRetryAt DateTime?

  conditionResult Boolean?
  selectedPath    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  run WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)

  // Indexes
  @@index([runId])
  @@index([taskId])
  @@index([status])
}

// ============================================================
// RATE LIMITING
// ============================================================

model RateLimitRule {
  id     Int     @id @default(autoincrement())
  type   String  @db.VarChar(50) // "per_user", "per_action", "global"
  target String  @db.VarChar(255) // userId, actionType, or "global"

  limit   Int // requests
  window  Int // milliseconds

  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, target])
  @@index([enabled])
}

// ============================================================
// NOTIFICATIONS & ALERTS
// ============================================================

model NotificationRule {
  id     Int     @id @default(autoincrement())
  trigger String @db.VarChar(100) // "on_failure", "on_retry_exhausted", "on_timeout"
  actionType String? @db.VarChar(100) // Specific action, or null for all

  method      String @db.VarChar(50) // "email", "webhook", "sms"
  destination String @db.VarChar(500) // email address, webhook URL, phone

  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([trigger])
  @@index([enabled])
}

// ============================================================
// METRICS & MONITORING
// ============================================================

model ActionMetric {
  id     Int    @id @default(autoincrement())
  actionType String @unique @db.VarChar(100)

  executionCount Int @default(0)
  successCount   Int @default(0)
  failureCount   Int @default(0)

  avgDuration Float @default(0) // milliseconds
  maxDuration Int?
  minDuration Int?
  p95Duration Int?
  p99Duration Int?

  lastExecutedAt DateTime?
  lastError      String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActionTemplate {
  id     Int     @id @default(autoincrement())
  actionType String @unique @db.VarChar(100)
  name   String  @db.VarChar(255)
  description String? @db.Text

  inputSchema  Json // JSON Schema
  outputSchema Json // What this action returns

  category  String  @db.VarChar(100) // "email", "domain", "billing", "server"
  isBuiltin Boolean @default(true)
  isActive  Boolean @default(true)

  documentation String? @db.Text
  examples       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}


////////////////////////////////////////////////////////////
// MARKETPLACE SYSTEM (FR-M1 → FR-M11)
////////////////////////////////////////////////////////////

/////////////////////////
// ENUMS
/////////////////////////

enum MarketplaceSubmissionStatus {
  pending_review
  pending_dependency_approval
  pending_resubmission
  rejected
  auto_rejected
  approved
}

/////////////////////////
// CATEGORY
/////////////////////////

model MarketplaceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products MarketplaceProduct[]
}

/////////////////////////
// PRODUCT
/////////////////////////

model MarketplaceProduct {
  id String @id @default(uuid())

  sellerId String
  seller   DeveloperProfile @relation("dev_products", fields: [sellerId], references: [id])

  title     String
  slug      String  @unique
  shortDesc String?
  longDesc  String?

  categoryId String?
  category   MarketplaceCategory? @relation(fields: [categoryId], references: [id])

  tags         String[] @default([])
  status       String   @default("draft")
  rejectReason String?

  logo        String?
  screenshots String[] @default([])

  documentation String?

  ratingAvg     Float @default(0)
  ratingCount   Int   @default(0)
  installCount  Int   @default(0)
  downloadCount Int   @default(0)

  lastUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approvedAt    DateTime?

  versions      MarketplaceVersion[]
  purchases     MarketplacePurchase[]
  reviews       MarketplaceReview[]
  dependencies  MarketplaceDependency[]
  submissions   MarketplaceSubmission[]
  verifications MarketplaceVerification[]
  analytics     MarketplaceAnalytics[]
}

/////////////////////////
// VERSION
/////////////////////////

model MarketplaceVersion {
  id        String             @id @default(uuid())
  productId String
  product   MarketplaceProduct @relation(fields: [productId], references: [id])

  version      String
  manifestJson Json
  archivePath  String
  changelog    String?

  priceCents Int
  currency   String @default("USD")

  createdAt  DateTime  @default(now())
  approvedAt DateTime? // REQUIRED for approval pipeline

  purchases     MarketplacePurchase[]
  analytics     MarketplaceAnalytics[]
  submissions   MarketplaceSubmission[]
  verifications MarketplaceVerification[]
}

/////////////////////////
// PURCHASE & LICENSE
/////////////////////////

model MarketplacePurchase {
  id         String @id @default(uuid())
  userId     String
  productId  String
  versionId  String
  licenseKey String @unique

  subscribed      Boolean   @default(false)
  activationLimit Int       @default(1)
  expiresAt       DateTime?
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  user    User               @relation(fields: [userId], references: [id])
  product MarketplaceProduct @relation(fields: [productId], references: [id])
  version MarketplaceVersion @relation(fields: [versionId], references: [id])

  activations MarketplaceLicenseActivation[]
}

model MarketplaceLicenseActivation {
  id        String   @id @default(uuid())
  licenseId String
  userAgent String?
  host      String?
  ip        String?
  createdAt DateTime @default(now())

  purchase MarketplacePurchase @relation(fields: [licenseId], references: [id])
}

/////////////////////////
// REVIEWS
/////////////////////////

model MarketplaceReview {
  id        String @id @default(uuid())
  productId String
  userId    String

  rating    Int
  stability Int?
  review    String?

  createdAt DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
  user    User               @relation(fields: [userId], references: [id])
}

/////////////////////////
// DEPENDENCIES
/////////////////////////

model MarketplaceDependency {
  id           String   @id @default(uuid())
  productId    String
  dependencyId String
  versionRange String
  approved     Boolean  @default(false) // REQUIRED for dependency approval pipeline
  createdAt    DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
}

/////////////////////////
// SUBMISSIONS
/////////////////////////

model MarketplaceSubmission {
  id         String                      @id @default(uuid())
  productId  String
  versionId  String?
  status     MarketplaceSubmissionStatus
  reviewerId String?
  notes      String?
  createdAt  DateTime                    @default(now())

  product  MarketplaceProduct  @relation(fields: [productId], references: [id])
  version  MarketplaceVersion? @relation(fields: [versionId], references: [id])
  reviewer User?               @relation(fields: [reviewerId], references: [id])
}

/////////////////////////
// VERIFICATION
/////////////////////////

model MarketplaceVerification {
  id        String @id @default(uuid())
  productId String
  versionId String

  passed    Boolean
  issues    Json?
  createdAt DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
  version MarketplaceVersion @relation(fields: [versionId], references: [id])
}

/////////////////////////
// ANALYTICS
/////////////////////////

model MarketplaceAnalytics {
  id        String  @id @default(uuid())
  productId String
  versionId String?

  product MarketplaceProduct  @relation(fields: [productId], references: [id])
  version MarketplaceVersion? @relation(fields: [versionId], references: [id])

  eventType String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([versionId])
  @@index([eventType])
  @@index([createdAt])
}

/////////////////////////
// ACTIVE INSTANCES
/////////////////////////

model MarketplaceActiveInstance {
  id         String   @id @default(uuid())
  productId  String
  versionId  String?
  instanceId String
  userId     String?
  lastSeen   DateTime @default(now())
  createdAt  DateTime @default(now())
  meta       Json?

  @@index([productId])
  @@index([instanceId])
  @@index([lastSeen])
}

/////////////////////////
// CRASH LOGS
/////////////////////////

model MarketplaceCrash {
  id        String  @id @default(uuid())
  productId String
  versionId String?
  userId    String?

  message    String
  stackTrace String?  @db.Text
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([versionId])
  @@index([createdAt])
}

/////////////////////////
// PERFORMANCE METRICS
/////////////////////////

model MarketplacePerfMetric {
  id        String  @id @default(uuid())
  productId String
  versionId String?

  metric    String
  value     Float
  meta      Json?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([metric])
  @@index([createdAt])
}

/////////////////////////
// DAILY AGGREGATES
/////////////////////////

model MarketplaceAnalyticsAggregate {
  id        String   @id @default(uuid())
  productId String
  date      DateTime
  installs  Int      @default(0)
  active    Int      @default(0)
  crashes   Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([productId, date])
  @@index([productId, date])
}

/////////////////////////
// WEBHOOK ENDPOINTS
/////////////////////////

model MarketplaceWebhookEndpoint {
  id        String   @id @default(uuid())
  vendorId  String
  url       String
  secret    String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([vendorId])
}

/////////////////////////
// BUILD LOGS
/////////////////////////

model MarketplaceBuildLog {
  id           String  @id @default(uuid())
  submissionId String?
  productId    String?
  versionId    String?

  level     String   @default("info")
  message   String
  meta      Json?
  step      String?
  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([productId])
  @@index([versionId])
  @@index([createdAt])
}

/////////////////////////
// WEBHOOK EVENTS
/////////////////////////

model MarketplaceWebhook {
  id        String   @id @default(uuid())
  event     String
  payload   Json
  createdAt DateTime @default(now())
}

////////////////////////////////////////////////////////////
// IP ACCESS RULES
////////////////////////////////////////////////////////////

model IpAccessRule {
  id          Int        @id @default(autoincrement())
  pattern     String
  type        IpRuleType
  description String?    @db.Text
  active      Boolean    @default(true)
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([pattern])
}

enum IpRuleType {
  ALLOW
  DENY
}

////////////////////////////////////////////////////////////
// SERVICES (Hosting Products Catalog)
////////////////////////////////////////////////////////////

model Service {
  id          Int     @id @default(autoincrement())
  code        String  @unique // internal reference (e.g. shared_hosting)
  name        String
  description String
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans ServicePlan[]

  @@index([active])
}

model ServicePlan {
  id        Int     @id @default(autoincrement())
  serviceId Int
  name      String // Basic, Pro, Business
  summary   String?
  active    Boolean @default(true)
  position  Int     @default(0)

  service Service @relation(fields: [serviceId], references: [id])

  pricing  ServicePricing[]
  policies ServicePolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, name])
  @@index([serviceId])
}

enum BillingCycle {
  monthly
  quarterly
  semi_annually
  annually
}

model ServicePricing {
  id       Int          @id @default(autoincrement())
  planId   Int
  cycle    BillingCycle
  price    Decimal      @db.Decimal(10, 2)
  currency String       @default("USD")
  active   Boolean      @default(true)

  plan ServicePlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, cycle])
  @@index([planId])
}

model ServicePolicy {
  id       Int     @id @default(autoincrement())
  planId   Int
  key      String
  value    Json
  enforced Boolean @default(true)

  plan ServicePlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())

  @@unique([planId, key])
}

model ServiceSnapshot {
  id        Int  @id @default(autoincrement())
  serviceId Int
  planId    Int?

  snapshot  Json
  orders    Order[]
  createdAt DateTime @default(now())

  @@index([serviceId])
}

/////////orders//////////
enum OrderStatus {
  pending
  active
  suspended
  terminated
   cancelled 
}

model Order {
  id        String   @id @default(uuid())
  clientId  String
  client    User     @relation(fields: [clientId], references: [id])

  snapshotId Int
  snapshot   ServiceSnapshot @relation(fields: [snapshotId], references: [id])

  status     OrderStatus @default(pending)

  // NEW
  startedAt       DateTime?
  nextRenewalAt   DateTime?
  suspendedAt     DateTime?
  terminatedAt    DateTime?
  cancelledAt     DateTime? 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([nextRenewalAt])
}
