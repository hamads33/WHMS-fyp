  cpuUsage   Float
  ramUsage   Float
  diskUsage  Float
  latency    Int
  uptime     Int
  recordedAt DateTime @default(now())
  server     Server   @relation(fields: [serverId], references: [id])

  @@index([serverId])
  @@index([recordedAt])
  @@index([serverId, recordedAt])
}

model ServerWebhook {
  id        String   @id @default(uuid())
  url       String
  events    String[]
  isActive  Boolean  @default(true)
  secret    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model ServiceCustomField {
  id              String   @id @default(uuid())
  serviceId       String
  fieldName       String
  fieldType       String   @default("text")
  description     String?
  validation      String?
  selectOptions   String?
  displayOrder    Int      @default(0)
  adminOnly       Boolean  @default(false)
  requiredField   Boolean  @default(false)
  showOnOrderForm Boolean  @default(false)
  showOnInvoice   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  service         Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@index([serviceId])
}

model ServiceCrossSell {
  id                 String   @id @default(uuid())
  serviceId          String
  crossSellServiceId String
  displayOrder       Int      @default(0)
  createdAt          DateTime @default(now())
  crossSellService   Service  @relation("CrossSellTarget", fields: [crossSellServiceId], references: [id], onDelete: Cascade)
  service            Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, crossSellServiceId])
  @@index([serviceId])
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

