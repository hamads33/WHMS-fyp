generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String                  @id @default(uuid())
  email                  String                  @unique
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  emailVerified          Boolean                 @default(false)
  mfaBackupCodes         String[]                @default([])
  mfaEnabled             Boolean                 @default(false)
  mfaSecret              String?
  passwordHash           String
  disabled               Boolean                 @default(false)
  adminProfile           AdminProfile?
  apiKeys                ApiKey[]
  auditLogs              AuditLog[]
  backups                Backup[]
  billingProfile         BillingProfile?
  chatAgent              ChatAgent?
  chatMessages           ChatMessage[]
  chatSessions           ChatSession[]
  chatSessionAgents      ChatSessionAgent[]
  clientProfile          ClientProfile?
  developerProfile       DeveloperProfile?
  domains                Domain[]
  emailTokens            EmailToken[]
  hostingAccounts        HostingAccount[]        @relation("HostingAccounts")
  impersonationsStarted  Impersonation[]         @relation("Impersonator")
  impersonationsReceived Impersonation[]         @relation("Impersonated")
  invoices               Invoice[]
  ipAccessRules          IpAccessRule[]
  loginLogs              LoginLog[]
  marketplacePurchases   MarketplacePurchase[]
  marketplaceReviews     MarketplaceReview[]
  marketplaceSubmissions MarketplaceSubmission[]
  orders                 Order[]
  payments               Payment[]
  paymentMethods         PaymentMethod[]
  refreshTokens          RefreshToken[]
  resellerProfile        ResellerProfile?
  serverManagedAccounts  ServerManagedAccount[]  @relation("ServerManagedAccounts")
  sessions               Session[]
  storageConfigs         StorageConfig[]
  assignedTickets        Ticket[]                @relation("AssignedStaff")
  tickets                Ticket[]
  ticketAttachments      TicketAttachment[]
  departmentMemberships  TicketDepartmentAgent[]
  ticketReplies          TicketReply[]
  ticketStatusChanges    TicketStatusHistory[]
  trustedDevices         TrustedDevice[]
  roles                  UserRole[]
  broadcastsCreated      Broadcast[]              @relation("BroadcastCreator")
  broadcastDismissals    BroadcastDismissal[]     @relation("BroadcastDismissalUser")
  broadcastEngagements   BroadcastEngagement[]    @relation("BroadcastEngagementUser")
  websites               Website[]
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  rolePerms   RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id])
  role         Role       @relation(fields: [roleId], references: [id])

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  userId String
  roleId String
  role   Role   @relation(fields: [roleId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@unique([userId, roleId])
}

model Session {
  id                  String   @id @default(uuid())
  userId              String
  token               String   @unique
  userAgent           String?
  ip                  String?
  createdAt           DateTime @default(now())
  expiresAt           DateTime
  isImpersonation     Boolean  @default(false)
  impersonatorId      String?
  impersonationReason String?
  updatedAt           DateTime @updatedAt
  country             String?
  deviceHash          String?
  lastActivity        DateTime @default(now())
  user                User     @relation(fields: [userId], references: [id])
}

model TrustedDevice {
  id         String   @id @default(uuid())
  userId     String
  deviceId   String   @unique
  userAgent  String?
  ip         String?
  name       String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @updatedAt
  expiresAt  DateTime
  revoked    Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id])
}

model ApiKey {
  id        String        @id @default(uuid())
  userId    String
  name      String
  keyHash   String
  createdAt DateTime      @default(now())
  revoked   Boolean       @default(false)
  expiresAt DateTime?
  user      User          @relation(fields: [userId], references: [id])
  scopes    ApiKeyScope[]
}

model ApiKeyScope {
  id       String @id @default(uuid())
  apiKeyId String
  scope    String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id])
}

model LoginLog {
  id        String   @id @default(uuid())
  userId    String?
  userEmail String?
  success   Boolean
  ip        String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())
  user      User?    @relation(fields: [userId], references: [id])
}

model ClientProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  firstName String?
  lastName  String?
  company   String?
  phone     String?
  address   String?
  country   String?
  city      String?
  postal    String?
  user      User    @relation(fields: [userId], references: [id])
}

model AdminProfile {
  id              String  @id @default(uuid())
  userId          String  @unique
  department      String?
  staffTitle      String?
  restrictionJson Json?
  user            User    @relation(fields: [userId], references: [id])
}

model ResellerProfile {
  id           String  @id @default(uuid())
  userId       String  @unique
  resellerCode String  @unique
  company      String?
  phone        String?
  address      String?
  user         User    @relation(fields: [userId], references: [id])
}

model DeveloperProfile {
  id              String               @id @default(uuid())
  userId          String               @unique
  displayName     String?
  website         String?
  github          String?
  payoutsEmail    String?
  createdAt       DateTime             @default(now())
  marketplaceMeta Json?
  publicKeyPem    String?
  storeName       String?
  stripeAccountId String?
  updatedAt       DateTime             @updatedAt
  user            User                 @relation(fields: [userId], references: [id])
  products        MarketplaceProduct[] @relation("dev_products")
}

model Impersonation {
  id             String    @id @default(uuid())
  adminId        String
  impersonatedId String
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  sessionToken   String    @unique
  reason         String?
  admin          User      @relation("Impersonator", fields: [adminId], references: [id])
  impersonated   User      @relation("Impersonated", fields: [impersonatedId], references: [id])
}

model EmailToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  type      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
  user      User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  userId    String?
  action    String
  createdAt DateTime           @default(now())
  data      Json?
  entity    String?
  entityId  String?
  ip        String?
  userAgent String?
  actor     String
  level     String             @default("INFO")
  meta      Json?
  source    String
  id        Int                @id @default(autoincrement())
  profileId Int?
  profile   AutomationProfile? @relation(fields: [profileId], references: [id])
  user      User?              @relation(fields: [userId], references: [id])

  @@index([profileId])
}

model WebhookEvent {
  id        String   @id @default(uuid())
  event     String
  data      Json
  processed Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([event])
}

model Domain {
  id                String           @id @default(uuid())
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  autoRenew         Boolean          @default(true)
  currency          String           @default("USD")
  expiryDate        DateTime?
  metadata          Json?
  name              String           @unique
  nameservers       Json?
  ownerId           String
  registrar         String?
  registrationPrice Int?
  renewalPrice      Int?
  status            DomainStatus     @default(pending_registration)
  dnsRecords        DNSRecord[]
  user              User             @relation(fields: [ownerId], references: [id])
  contacts          DomainContact[]
  logs              DomainLog[]
  transfers         DomainTransfer[]

  @@index([ownerId])
  @@index([status])
  @@index([expiryDate])
}

model DNSRecord {
  id               Int      @id @default(autoincrement())
  domainId         String
  type             String
  name             String
  value            String
  ttl              Int      @default(3600)
  providerRecordId String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  domain           Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
}

model DomainContact {
  id        Int               @id @default(autoincrement())
  domainId  String
  type      DomainContactType
  name      String
  email     String
  phone     String?
  country   String
  createdAt DateTime          @default(now())
  domain    Domain            @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@unique([domainId, type])
}

model DomainTransfer {
  id               Int                  @id @default(autoincrement())
  domainId         String
  authCode         String
  status           DomainTransferStatus @default(pending)
  requestedAt      DateTime             @default(now())
  completedAt      DateTime?
  providerResponse Json?
  domain           Domain               @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([status])
}

model DomainLog {
  id        Int      @id @default(autoincrement())
  domainId  String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
  domain    Domain   @relation(fields: [domainId], references: [id], onDelete: Cascade)

  @@index([domainId])
}

model TldPricing {
  id           Int      @id @default(autoincrement())
  tld          String   @unique
  registration Decimal  @db.Decimal(10, 2)
  renewal      Decimal  @db.Decimal(10, 2)
  transfer     Decimal  @db.Decimal(10, 2)
  provider     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model TicketDepartment {
  id                String                  @id @default(uuid())
  name              String                  @unique
  slug              String                  @unique
  description       String?
  email             String?
  active            Boolean                 @default(true)
  slaResponseTime   Int?
  slaResolutionTime Int?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt
  chatSessions      ChatSession[]
  tickets           Ticket[]
  agents            TicketDepartmentAgent[]
}

model TicketDepartmentAgent {
  id           String           @id @default(uuid())
  departmentId String
  userId       String
  isLead       Boolean          @default(false)
  assignedAt   DateTime         @default(now())
  department   TicketDepartment @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([departmentId, userId])
  @@index([userId])
}

model Ticket {
  id              String                @id @default(uuid())
  subject         String
  createdAt       DateTime              @default(now())
  closedAt        DateTime?
  updatedAt       DateTime              @updatedAt
  assignedToId    String?
  clientId        String
  departmentId    String
  firstResponseAt DateTime?
  metadata        Json?
  relatedOrderId  String?
  resolvedAt      DateTime?
  slaBreachedAt   DateTime?
  ticketNumber    String                @unique
  priority        TicketPriority        @default(medium)
  status          TicketStatus          @default(open)
  chatSession     ChatSession?
  assignedTo      User?                 @relation("AssignedStaff", fields: [assignedToId], references: [id])
  client          User                  @relation(fields: [clientId], references: [id])
  department      TicketDepartment      @relation(fields: [departmentId], references: [id])
  attachments     TicketAttachment[]
  replies         TicketReply[]
  statusHistory   TicketStatusHistory[]

  @@index([clientId])
  @@index([assignedToId])
  @@index([departmentId])
  @@index([status])
  @@index([priority])
  @@index([ticketNumber])
  @@index([createdAt])
}

model TicketReply {
  id          String             @id @default(uuid())
  ticketId    String
  createdAt   DateTime           @default(now())
  authorId    String
  body        String
  isEdited    Boolean            @default(false)
  type        ReplyType          @default(public)
  updatedAt   DateTime           @updatedAt
  attachments TicketAttachment[]
  author      User               @relation(fields: [authorId], references: [id])
  ticket      Ticket             @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
  @@index([createdAt])
}

model TicketAttachment {
  id           String       @id @default(uuid())
  ticketId     String
  replyId      String?
  fileName     String
  mimeType     String
  sizeBytes    Int
  storageKey   String
  url          String?
  uploadedById String
  createdAt    DateTime     @default(now())
  reply        TicketReply? @relation(fields: [replyId], references: [id])
  ticket       Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation(fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@index([replyId])
}

model TicketStatusHistory {
  id           String          @id @default(uuid())
  ticketId     String
  changedById  String
  fromStatus   TicketStatus?
  toStatus     TicketStatus
  fromPriority TicketPriority?
  toPriority   TicketPriority?
  note         String?
  createdAt    DateTime        @default(now())
  changedBy    User            @relation(fields: [changedById], references: [id])
  ticket       Ticket          @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([createdAt])
}

model ChatSession {
  id                  String             @id @default(uuid())
  sessionCode         String             @unique
  clientId            String
  departmentId        String?
  status              ChatSessionStatus  @default(waiting)
  subject             String?
  convertedToTicketId String?            @unique
  startedAt           DateTime           @default(now())
  endedAt             DateTime?
  agentJoinedAt       DateTime?
  rating              Int?
  feedback            String?
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  messages            ChatMessage[]
  client              User               @relation(fields: [clientId], references: [id])
  convertedToTicket   Ticket?            @relation(fields: [convertedToTicketId], references: [id])
  department          TicketDepartment?  @relation(fields: [departmentId], references: [id])
  agents              ChatSessionAgent[]

  @@index([clientId])
  @@index([departmentId])
  @@index([status])
  @@index([startedAt])
}

model ChatSessionAgent {
  id        String      @id @default(uuid())
  sessionId String
  agentId   String
  joinedAt  DateTime    @default(now())
  leftAt    DateTime?
  isPrimary Boolean     @default(false)
  agent     User        @relation(fields: [agentId], references: [id])
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, agentId])
  @@index([agentId])
}

model ChatMessage {
  id        String          @id @default(uuid())
  sessionId String
  senderId  String
  type      ChatMessageType @default(text)
  body      String
  metadata  Json?
  sentAt    DateTime        @default(now())
  sender    User            @relation(fields: [senderId], references: [id])
  session   ChatSession     @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([senderId])
  @@index([sentAt])
}

model ChatAgent {
  id                 String    @id @default(uuid())
  userId             String    @unique
  isOnline           Boolean   @default(false)
  maxConcurrentChats Int       @default(3)
  currentChatCount   Int       @default(0)
  acceptingChats     Boolean   @default(true)
  lastSeenAt         DateTime?
  updatedAt          DateTime  @updatedAt
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

model MarketplaceProduct {
  id            String              @id @default(uuid())
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  category      String?
  description   String?
  devId         String
  name          String
  published     Boolean             @default(false)
  rating        Decimal             @default(0) @db.Decimal(3, 2)
  slug          String              @unique
  iconUrl       String?
  screenshots   String[]
  pricingType   String              @default("free")
  price         Int                 @default(0)
  currency      String              @default("USD")
  interval      String?
  visibility    String              @default("public")
  status        String              @default("draft")
  zipPath       String?
  downloadUrl   String?
  version       String?
  changelog     String?
  checksum      String?
  totalRevenue  Decimal             @default(0) @db.Decimal(10, 2)
  salesCount    Int                 @default(0)
  dev           DeveloperProfile    @relation("dev_products", fields: [devId], references: [id])
  reviews       MarketplaceReview[]
  purchases     MarketplacePurchase[]

  @@index([status])
  @@index([visibility])
  @@index([devId])
}

model MarketplaceReview {
  id        String             @id @default(uuid())
  productId String
  userId    String
  rating    Int
  createdAt DateTime           @default(now())
  text      String?
  title     String?
  product   MarketplaceProduct @relation(fields: [productId], references: [id])
  user      User               @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([productId])
}

model MarketplaceSubmission {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  json      Json?
  name      String
  userId    String
  status    String   @default("pending")
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
}

model MarketplacePurchase {
  id        String             @id @default(uuid())
  userId    String
  productId String
  price     Int                @default(0)
  currency  String             @default("USD")
  status    String             @default("completed")
  createdAt DateTime           @default(now())
  user      User               @relation(fields: [userId], references: [id])
  product   MarketplaceProduct @relation(fields: [productId], references: [id])

  @@index([userId])
  @@index([productId])
}

model AutomationProfile {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  cron        String
  enabled     Boolean          @default(false)
  auditLogs   AuditLog[]
  runs        AutomationRun[]
  tasks       AutomationTask[]
}

model AutomationTask {
  createdAt  DateTime          @default(now())
  actionMeta Json              @default("{}")
  actionType String
  order      Int               @default(0)
  profileId  Int
  updatedAt  DateTime          @updatedAt
  id         Int               @id @default(autoincrement())
  profile    AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model AutomationRun {
  id           Int               @id @default(autoincrement())
  profileId    Int
  taskId       Int?
  status       String            @default("pending")
  startedAt    DateTime?
  finishedAt   DateTime?
  result       Json?
  errorMessage String?
  createdAt    DateTime          @default(now())
  profile      AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
}

model AutomationWorkflow {
  id          String                @id @default(uuid())
  name        String
  description String                @default("")
  definition  Json
  enabled     Boolean               @default(true)
  version     Int                   @default(1)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  deletedAt   DateTime?
  eventFilter Json?
  eventType   String?
  slug        String                @unique
  trigger     String                @default("manual")
  type        String                @default("sequential")
  webhooks    IncomingWebhook[]
  runs        WorkflowRun[]
  triggers    WorkflowTriggerRule[]
}

model IncomingWebhook {
  id             String             @id @default(uuid())
  workflowId     String
  url            String
  secret         String
  enabled        Boolean            @default(true)
  events         Json               @default("[]")
  retryPolicy    Json?
  totalReceived  Int                @default(0)
  lastReceivedAt DateTime?
  failureCount   Int                @default(0)
  lastError      String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  workflow       AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
}

model WorkflowTriggerRule {
  id               String             @id @default(uuid())
  workflowId       String
  eventType        String
  enabled          Boolean            @default(true)
  conditions       Json?
  passEventAsInput Boolean            @default(false)
  inputMapping     Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  workflow         AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, eventType])
}

model WorkflowRun {
  id            String             @id @default(uuid())
  workflowId    String
  status        String             @default("pending")
  triggeredBy   String             @default("manual")
  input         Json?
  output        Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  errorMessage  String?
  errorStack    String?
  totalDuration Int?
  successCount  Int                @default(0)
  failureCount  Int                @default(0)
  taskCount     Int                @default(0)
  skippedCount  Int                @default(0)
  createdAt     DateTime           @default(now())
  triggerId     String?
  workflow      AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  taskRuns      WorkflowTaskRun[]
}

model WorkflowTaskRun {
  id              String      @id @default(uuid())
  runId           String
  taskId          String
  status          String      @default("pending")
  retryCount      Int         @default(0)
  maxRetries      Int         @default(0)
  startedAt       DateTime?
  finishedAt      DateTime?
  duration        Int?
  output          Json?
  errorMessage    String?
  errorStack      String?
  conditionResult Boolean?
  selectedPath    String?
  nextRetryAt     DateTime?
  createdAt       DateTime    @default(now())
  run             WorkflowRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model ServiceGroup {
  id          String    @id @default(uuid())
  name        String    @unique
  slug        String    @unique
  description String?
  icon        String?
  position    Int       @default(0)
  active      Boolean   @default(true)
  hidden      Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  services    Service[]
}

model Service {
  id                   String                 @id @default(uuid())
  code                 String                 @unique
  name                 String
  description          String?
  shortDescription     String?
  groupId              String?
  parentServiceId      String?
  moduleName           String?
  moduleType           String?
  active               Boolean                @default(true)
  hidden               Boolean                @default(false)
  taxable              Boolean                @default(true)
  autoSetup            Boolean                @default(true)
  autoSuspend          Boolean                @default(true)
  autoTerminate        Boolean                @default(false)
  customizeOption      String                 @default("none")
  paymentType          String                 @default("regular")
  requiresDomain       Boolean                @default(false)
  allowAutoRenew       Boolean                @default(true)
  billingCycles        String                 @default("monthly,quarterly,semi_annually,annually")
  position             Int                    @default(0)
  createdAt            DateTime               @default(now())
  updatedAt            DateTime               @updatedAt
  autoTerminateDays    Int                    @default(0)
  chargeNextMonth      Int                    @default(0)
  color                String?
  featured             Boolean                @default(false)
  multipleQuantities   String                 @default("no")
  onDemandRenewals     Boolean                @default(true)
  prorataBilling       Boolean                @default(false)
  prorataDate          Int                    @default(0)
  recurringCyclesLimit Int                    @default(0)
  retired              Boolean                @default(false)
  serverGroup          String?
  tagline              String?
  welcomeEmailTemplate String?
  group                ServiceGroup?          @relation(fields: [groupId], references: [id])
  parentService        Service?               @relation("ServiceBundle", fields: [parentServiceId], references: [id])
  childServices        Service[]              @relation("ServiceBundle")
  addons               ServiceAddon[]
  automations          ServiceAutomation[]
  configurations       ServiceConfiguration[]
  crossSellTargets     ServiceCrossSell[]     @relation("CrossSellTarget")
  crossSells           ServiceCrossSell[]
  customFields         ServiceCustomField[]
  features             ServiceFeature[]
  plans                ServicePlan[]
  policies             ServicePolicy[]

  @@index([groupId])
  @@index([parentServiceId])
  @@index([active])
}

model ServiceAddon {
  id           String                @id @default(uuid())
  serviceId    String
  name         String
  description  String?
  code         String
  setupFee     Decimal               @default(0) @db.Decimal(10, 2)
  monthlyPrice Decimal               @db.Decimal(10, 2)
  currency     String                @default("USD")
  maxQuantity  Int?
  required     Boolean               @default(false)
  recurring    Boolean               @default(true)
  billingType  String                @default("shared")
  active       Boolean               @default(true)
  position     Int                   @default(0)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
