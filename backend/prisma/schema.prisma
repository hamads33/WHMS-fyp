////////////////////////////////////////////////////////////
// DATABASE + GENERATOR
////////////////////////////////////////////////////////////

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

////////////////////////////////////////////////////////////
// USERS (Single Identity for all roles)
////////////////////////////////////////////////////////////

model User {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String

  emailVerified  Boolean  @default(false)
  disabled       Boolean  @default(false)
  mfaEnabled     Boolean  @default(false)
  mfaSecret      String?
  mfaBackupCodes String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // RBAC
  roles UserRole[]

  // Auth & Security
  sessions               Session[]
  apiKeys                ApiKey[]
  loginLogs              LoginLog[]
  trustedDevices         TrustedDevice[]
  emailTokens            EmailToken[]
  auditLogs              AuditLog[]
  domains                Domain[]
  orders                 Order[]
  // Impersonation
  impersonationsStarted  Impersonation[] @relation("Impersonator")
  impersonationsReceived Impersonation[] @relation("Impersonated")

  // Portal Profiles
  clientProfile    ClientProfile?
  adminProfile     AdminProfile?
  resellerProfile  ResellerProfile?
  developerProfile DeveloperProfile?

  // Marketplace
  marketplaceReviews     MarketplaceReview[]
  marketplaceSubmissions MarketplaceSubmission[]
  marketplacePurchases   MarketplacePurchase[]
  billingProfile         BillingProfile?
  invoices               Invoice[]
  payments               Payment[]

  // Tickets
  tickets Ticket[]

  // Legacy
  refreshTokens RefreshToken[]
}

////////////////////////////////////////////////////////////
// ROLE SYSTEM (RBAC)
////////////////////////////////////////////////////////////

model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  rolePerms   RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String

  @@unique([userId, roleId])
}

////////////////////////////////////////////////////////////
// SESSIONS
////////////////////////////////////////////////////////////

model Session {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  token      String   @unique
  userAgent  String?
  ip         String?
  deviceHash String? // 🔐 hashed device fingerprint
  country    String? // 🌍 geo-IP (country only)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
  expiresAt  DateTime

  lastActivity        DateTime @default(now())
  isImpersonation     Boolean  @default(false)
  impersonatorId      String?
  impersonationReason String?
}

////////////////////////////////////////////////////////////
// TRUSTED DEVICES
////////////////////////////////////////////////////////////

model TrustedDevice {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  deviceId   String   @unique
  userAgent  String?
  ip         String?
  name       String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @updatedAt
  expiresAt  DateTime
  revoked    Boolean  @default(false)
}

////////////////////////////////////////////////////////////
// API KEYS
////////////////////////////////////////////////////////////

model ApiKey {
  id        String    @id @default(uuid())
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  name      String
  keyHash   String
  createdAt DateTime  @default(now())
  revoked   Boolean   @default(false)
  expiresAt DateTime?

  scopes ApiKeyScope[]
}

model ApiKeyScope {
  id       String @id @default(uuid())
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id])
  apiKeyId String
  scope    String
}

////////////////////////////////////////////////////////////
// LOGIN LOGS
////////////////////////////////////////////////////////////

model LoginLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  userEmail String?
  success   Boolean
  ip        String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())
}

////////////////////////////////////////////////////////////
// USER PROFILES
////////////////////////////////////////////////////////////

model ClientProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  company String?
  phone   String?
  address String?
  country String?
  city    String?
  postal  String?
}

model AdminProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  department      String?
  staffTitle      String?
  restrictionJson Json?
}

model ResellerProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  resellerCode String  @unique
  company      String?
  phone        String?
  address      String?
}

model DeveloperProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  displayName String?
  website     String?
  github      String?

  storeName       String?
  payoutsEmail    String?
  stripeAccountId String?
  publicKeyPem    String?
  marketplaceMeta Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products MarketplaceProduct[] @relation("dev_products")
}

////////////////////////////////////////////////////////////
// IMPERSONATION RECORDS
////////////////////////////////////////////////////////////

model Impersonation {
  id             String @id @default(uuid())
  adminId        String
  admin          User?  @relation("Impersonator", fields: [adminId], references: [id])
  impersonatedId String
  impersonated   User?  @relation("Impersonated", fields: [impersonatedId], references: [id])

  startedAt    DateTime  @default(now())
  endedAt      DateTime?
  sessionToken String    @unique
  reason       String?
}

////////////////////////////////////////////////////////////
// EMAIL TOKENS
////////////////////////////////////////////////////////////

model EmailToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tokenHash String
  type      String
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
}

////////////////////////////////////////////////////////////
// AUDIT LOGS
////////////////////////////////////////////////////////////

model AuditLog {
  id        Int                @id @default(autoincrement())
  source    String
  action    String
  actor     String
  level     String             @default("INFO")
  meta      Json?
  userId    String?
  ip        String?
  userAgent String?
  entity    String?
  entityId  String?
  data      Json?
  profileId Int?
  profile   AutomationProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  createdAt DateTime           @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([profileId])
}

////////////////////////////////////////////////////////////
// WEBHOOKS
////////////////////////////////////////////////////////////

model Webhook {
  id        String   @id @default(cuid())
  name      String   @unique
  url       String
  secret    String
  events    String[]
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logs WebhookLog[]
}

model WebhookLog {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  status     String
  httpStatus Int?
  attempts   Int      @default(0)
  lastError  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id])
}

////////////////////////////////////////////////////////////
// REFRESH TOKENS
////////////////////////////////////////////////////////////

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

////////////////////////////////////////////////////////////
// TICKETS
////////////////////////////////////////////////////////////

model Ticket {
  id        Int      @id @default(autoincrement())
  clientId  String
  subject   String
  message   String
  priority  String
  status    String   @default("open")
  createdAt DateTime @default(now())

  client User @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

////////////////////////////////////////////////////////////
// EMAIL SYSTEM
////////////////////////////////////////////////////////////

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  subject   String
  bodyHtml  String
  bodyText  String?
  language  String   @default("en")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs EmailJob[]
}

model EmailJob {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   Int?
  templateName String?
  toEmail      String
  toName       String?
  payload      Json?
  status       String   @default("queued")
  attempts     Int      @default(0)
  lastError    String?
  priority     String   @default("normal")
  provider     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@index([status])
}

model EmailEvent {
  id         Int      @id @default(autoincrement())
  jobId      String?
  eventType  String
  providerId String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([jobId])
}

////////////////////////////////////////////////////////////
// DOMAINS
////////////////////////////////////////////////////////////

enum DomainStatus {
  pending_registration
  active
  expired
  grace
  redemption
  transfer_pending
  transfer_failed
  transferred_out
  cancelled
}

enum DomainContactType {
  registrant
  admin
  tech
  billing
}

enum DomainTransferStatus {
  pending
  approved
  rejected
  completed
}

model Domain {
  id   Int    @id @default(autoincrement())
  name String @unique

  // Ownership
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id])

  // Registrar
  registrar        String?
  providerConfigId Int?
  providerConfig   ProviderConfig? @relation(fields: [providerConfigId], references: [id])

  // Lifecycle
  status     DomainStatus @default(pending_registration)
  expiryDate DateTime?
  autoRenew  Boolean      @default(true)

  // Billing snapshot (price locked at time of invoice)
  registrationPrice Int?
  renewalPrice      Int?
  currency          String @default("USD")

  // DNS
  nameservers String[] @default([])

  // Extra registrar / TLD specific fields
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  dnsRecords    DNSRecord[]
  contacts      DomainContact[]
  transfers     DomainTransfer[]
  registrarLogs DomainRegistrarCommand[]
  logs          DomainLog[]

  @@index([ownerId])
  @@index([status])
  @@index([expiryDate])
}

model DomainContact {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  type    DomainContactType
  name    String
  email   String
  phone   String
  country String

  createdAt DateTime @default(now())

  @@unique([domainId, type])
}

model DomainTransfer {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  authCode String
  status   DomainTransferStatus @default(pending)

  requestedAt DateTime  @default(now())
  completedAt DateTime?

  providerResponse Json?

  @@index([status])
}

model DNSRecord {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  type  String // A, AAAA, MX, TXT, CNAME
  name  String
  value String
  ttl   Int    @default(3600)

  providerRecordId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([domainId])
}

model DomainRegistrarCommand {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  action   String // register, renew, transfer, update_ns
  request  Json?
  response Json?
  success  Boolean

  createdAt DateTime @default(now())

  @@index([domainId])
  @@index([action])
}

model DomainLog {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id], onDelete: Cascade)

  action  String
  message String?
  meta    Json?

  createdAt DateTime @default(now())

  @@index([domainId])
}

model TldPricing {
  id           Int      @id @default(autoincrement())
  tld          String   @unique
  registration Decimal  @db.Decimal(10, 2)
  renewal      Decimal  @db.Decimal(10, 2)
  transfer     Decimal  @db.Decimal(10, 2)
  provider     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

////////////////////////////////////////////////////////////
// PROVIDER CONFIG
////////////////////////////////////////////////////////////

model ProviderConfig {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  key       String?
  secret    String?
  endpoint  String?
  active    Boolean  @default(true)
  domains   Domain[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StorageConfig {
  id          Int      @id @default(autoincrement())
  name        String
  provider    String
  config      Json
  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // FIX: Added indexes for better query performance
  @@index([createdById])
  @@index([provider])
}

////////////////////////////////////////////////////////////
// BACKUP SYSTEM
////////////////////////////////////////////////////////////

model Backup {
  id              String    @id @default(cuid())
  name            String
  type            String
  storageConfigId Int?
  filePath        String?
  sizeBytes       BigInt?
  status          String
  retentionDays   Int?
  createdById     String
  createdAt       DateTime  @default(now())
  startedAt       DateTime?
  finishedAt      DateTime?
  deleted         Boolean   @default(false)
  errorMessage    String?

  versions BackupVersion[]
  stepLogs BackupStepLog[]

  // FIX: Added composite index for retention policy queries
  // This dramatically improves performance when finding expired backups
  @@index([deleted, status, finishedAt])
  @@index([createdById])
  @@index([status])
}

model BackupVersion {
  id        String   @id @default(uuid())
  backupId  String
  version   Int      @default(1)
  filePath  String
  sizeBytes BigInt?
  createdAt DateTime @default(now())

  backup Backup @relation(fields: [backupId], references: [id])

  // FIX: Added indexes for version queries
  @@index([backupId])
  @@index([createdAt])
}

model BackupStepLog {
  id        String   @id @default(uuid())
  backupId  String
  step      String
  meta      Json?
  status    String   @default("started")
  message   String?
  createdAt DateTime @default(now())

  backup Backup @relation(fields: [backupId], references: [id])

  // FIX: Added indexes for log queries
  @@index([backupId])
  @@index([status])
  @@index([createdAt])
}

////////////////////////////////////////////////////////////
// TLD PRICING
////////////////////////////////////////////////////////////

model Tld {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  registerPrice Int?
  renewPrice    Int?
  transferPrice Int?
  markupPercent Int?
  providerData  Json?
  lastSynced    DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

////////////////////////////////////////////////////////////
// AUTOMATION SYSTEM
///////////////////////////////////////////////////////////

// ============================================================
// ENUMS - Define all enums first
// ============================================================

enum AutomationRunStatus {
  pending
  running
  success
  failed
}

// ============================================================
// AUTOMATION SYSTEM (Core)
// ============================================================

model AutomationProfile {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  description String? @db.Text
  cron        String? @db.VarChar(100)
  enabled     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  tasks     AutomationTask[]
  runs      AutomationRun[]
  auditLogs AuditLog[]

  // Indexes
  @@unique([name])
  @@index([enabled])
  @@index([cron])
}

model AutomationTask {
  id         Int    @id @default(autoincrement())
  profileId  Int
  actionType String @db.VarChar(100)
  actionMeta Json?
  order      Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  runs    AutomationRun[]

  // Indexes
  @@index([profileId])
  @@index([order])
}

model AutomationRun {
  id           Int                 @id @default(autoincrement())
  profileId    Int
  taskId       Int?
  status       AutomationRunStatus
  result       Json?
  errorMessage String?             @db.Text

  startedAt  DateTime?
  finishedAt DateTime?
  createdAt  DateTime  @default(now())

  // Relations
  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  task    AutomationTask?   @relation(fields: [taskId], references: [id], onDelete: SetNull)

  // Indexes
  @@index([profileId])
  @@index([taskId])
  @@index([status])
  @@index([createdAt])
}

///////////////workflows////////////////
model AutomationWorkflow {
  id          Int     @id @default(autoincrement())
  name        String  @db.VarChar(255)
  slug        String  @unique @db.VarChar(255) // ← ADD
  description String? @db.Text
  definition  Json
  enabled     Boolean @default(true)
  version     Int     @default(1)
  isDraft     Boolean @default(false)

  trigger     String  @default("manual") // ← ADD
  type        String  @default("sequential") // ← ADD
  eventType   String? // ← ADD
  eventFilter Json? // ← ADD

  webhookUrl    String? @unique // ← ADD
  webhookSecret String? @db.Text // ← ADD

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // ← ADD (soft delete)

  runs      WorkflowRun[]
  webhooks  IncomingWebhook[] // ← ADD
  triggers  WorkflowTriggerRule[] // ← ADD
  schedules WorkflowSchedule[] // ← ADD
  alerts    WorkflowAlert[] // ← ADD

  @@index([enabled])
  @@index([trigger]) // ← ADD
  @@index([eventType]) // ← ADD
  @@index([createdAt])
}

model WorkflowRun {
  id            Int                @id @default(autoincrement())
  workflowId    Int
  status        WorkflowRunStatus  @default(pending)
  startedAt     DateTime?
  finishedAt    DateTime?
  totalDuration Int?
  taskCount     Int                @default(0)
  successCount  Int                @default(0)
  failureCount  Int                @default(0)
  skippedCount  Int                @default(0)
  failedTaskId  String?
  errorMessage  String?            @db.Text
  errorStack    String?            @db.Text
  triggeredBy   String             @default("manual") // ← UPDATE: add "event", "api"
  triggerId     String? // ← ADD: ID of trigger source
  input         Json?
  output        Json?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  workflow      AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  taskRuns      WorkflowTaskRun[]

  @@index([workflowId])
  @@index([status])
  @@index([triggeredBy]) // ← ADD
  @@index([createdAt])
}

// KEEP EXACTLY AS IS - NO CHANGES NEEDED
model WorkflowTaskRun {
  id              Int                @id @default(autoincrement())
  runId           Int
  taskId          String
  status          WorkflowTaskStatus @default(pending)
  startedAt       DateTime?
  finishedAt      DateTime?
  duration        Int?
  output          Json?
  errorMessage    String?            @db.Text
  errorStack      String?            @db.Text
  retryCount      Int                @default(0)
  maxRetries      Int                @default(0)
  nextRetryAt     DateTime?
  conditionResult Boolean?
  selectedPath    String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  run             WorkflowRun        @relation(fields: [runId], references: [id], onDelete: Cascade)

  @@index([runId])
  @@index([taskId])
  @@index([status])
}

// KEEP EXACTLY AS IS - NO CHANGES NEEDED
model RateLimitRule {
  id        Int      @id @default(autoincrement())
  type      String   @db.VarChar(50)
  target    String   @db.VarChar(255)
  limit     Int
  window    Int
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([type, target])
  @@index([enabled])
}

// KEEP EXACTLY AS IS - NO CHANGES NEEDED
model NotificationRule {
  id          Int      @id @default(autoincrement())
  trigger     String   @db.VarChar(100)
  actionType  String?  @db.VarChar(100)
  method      String   @db.VarChar(50)
  destination String   @db.VarChar(500)
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())

  @@index([trigger])
  @@index([enabled])
}

// KEEP EXACTLY AS IS - NO CHANGES NEEDED
model ActionMetric {
  id             Int       @id @default(autoincrement())
  actionType     String    @unique @db.VarChar(100)
  executionCount Int       @default(0)
  successCount   Int       @default(0)
  failureCount   Int       @default(0)
  avgDuration    Float     @default(0)
  maxDuration    Int?
  minDuration    Int?
  p95Duration    Int?
  p99Duration    Int?
  lastExecutedAt DateTime?
  lastError      String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// KEEP EXACTLY AS IS - NO CHANGES NEEDED
model ActionTemplate {
  id            Int      @id @default(autoincrement())
  actionType    String   @unique @db.VarChar(100)
  name          String   @db.VarChar(255)
  description   String?  @db.Text
  inputSchema   Json
  outputSchema  Json
  category      String   @db.VarChar(100)
  isBuiltin     Boolean  @default(true)
  isActive      Boolean  @default(true)
  documentation String?  @db.Text
  examples      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model IncomingWebhook {
  id         String             @id @default(uuid())
  workflowId Int
  workflow   AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  url    String @unique
  secret String @db.Text

  enabled Boolean @default(true)

  totalReceived  Int       @default(0)
  lastReceivedAt DateTime?
  failureCount   Int       @default(0)
  lastError      String?   @db.Text

  events      String[]
  retryPolicy Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([enabled])
}

model WorkflowTriggerRule {
  id         String             @id @default(uuid())
  workflowId Int
  workflow   AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  eventType String

  conditions Json?

  passEventAsInput Boolean @default(true)
  inputMapping     Json?

  enabled Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([workflowId, eventType])
  @@index([eventType])
}

model WorkflowEvent {
  id String @id @default(uuid())

  type   String
  source String

  data     Json
  metadata Json?

  processed   Boolean   @default(false)
  processedAt DateTime?
  error       String?   @db.Text

  createdAt DateTime @default(now())

  @@index([type])
  @@index([source])
  @@index([processed])
  @@index([createdAt])
}

model WorkflowSchedule {
  id         String             @id @default(uuid())
  workflowId Int
  workflow   AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  cronExpression String

  enabled  Boolean @default(true)
  timezone String  @default("UTC")

  input Json?

  lastRunAt DateTime?
  nextRunAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([enabled])
}

model WorkflowAlert {
  id         String             @id @default(uuid())
  workflowId Int
  workflow   AutomationWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  condition String
  threshold Float

  notifyTo      String[]
  notifyMethod  String
  notifyWebhook String?

  enabled Boolean @default(true)

  lastAlertAt DateTime?
  alertCount  Int       @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([workflowId])
  @@index([condition])
}

enum WorkflowRunStatus {
  pending
  running
  success
  failed
  cancelled
  timeout
}

enum WorkflowTaskStatus {
  pending
  running
  success
  failed
  skipped
  timeout
}

////////////////////////////////////////////////////////////
// MARKETPLACE SYSTEM (FR-M1 → FR-M11)
////////////////////////////////////////////////////////////

/////////////////////////
// ENUMS
/////////////////////////

enum MarketplaceSubmissionStatus {
  pending_review
  pending_dependency_approval
  pending_resubmission
  rejected
  auto_rejected
  approved
}

/////////////////////////
// CATEGORY
/////////////////////////

model MarketplaceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products MarketplaceProduct[]
}

/////////////////////////
// PRODUCT
/////////////////////////

model MarketplaceProduct {
  id String @id @default(uuid())

  sellerId String
  seller   DeveloperProfile @relation("dev_products", fields: [sellerId], references: [id])

  title     String
  slug      String  @unique
  shortDesc String?
  longDesc  String?

  categoryId String?
  category   MarketplaceCategory? @relation(fields: [categoryId], references: [id])

  tags         String[] @default([])
  status       String   @default("draft")
  rejectReason String?

  logo        String?
  screenshots String[] @default([])

  documentation String?

  ratingAvg     Float @default(0)
  ratingCount   Int   @default(0)
  installCount  Int   @default(0)
  downloadCount Int   @default(0)

  lastUpdatedAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  approvedAt    DateTime?

  versions      MarketplaceVersion[]
  purchases     MarketplacePurchase[]
  reviews       MarketplaceReview[]
  dependencies  MarketplaceDependency[]
  submissions   MarketplaceSubmission[]
  verifications MarketplaceVerification[]
  analytics     MarketplaceAnalytics[]
}

/////////////////////////
// VERSION
/////////////////////////

model MarketplaceVersion {
  id        String             @id @default(uuid())
  productId String
  product   MarketplaceProduct @relation(fields: [productId], references: [id])

  version      String
  manifestJson Json
  archivePath  String
  changelog    String?

  priceCents Int
  currency   String @default("USD")

  createdAt  DateTime  @default(now())
  approvedAt DateTime? // REQUIRED for approval pipeline

  purchases     MarketplacePurchase[]
  analytics     MarketplaceAnalytics[]
  submissions   MarketplaceSubmission[]
  verifications MarketplaceVerification[]
}

/////////////////////////
// PURCHASE & LICENSE
/////////////////////////

model MarketplacePurchase {
  id         String @id @default(uuid())
  userId     String
  productId  String
  versionId  String
  licenseKey String @unique

  subscribed      Boolean   @default(false)
  activationLimit Int       @default(1)
  expiresAt       DateTime?
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now())

  user    User               @relation(fields: [userId], references: [id])
  product MarketplaceProduct @relation(fields: [productId], references: [id])
  version MarketplaceVersion @relation(fields: [versionId], references: [id])

  activations MarketplaceLicenseActivation[]
}

model MarketplaceLicenseActivation {
  id        String   @id @default(uuid())
  licenseId String
  userAgent String?
  host      String?
  ip        String?
  createdAt DateTime @default(now())

  purchase MarketplacePurchase @relation(fields: [licenseId], references: [id])
}

/////////////////////////
// REVIEWS
/////////////////////////

model MarketplaceReview {
  id        String @id @default(uuid())
  productId String
  userId    String

  rating    Int
  stability Int?
  review    String?

  createdAt DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
  user    User               @relation(fields: [userId], references: [id])
}

/////////////////////////
// DEPENDENCIES
/////////////////////////

model MarketplaceDependency {
  id           String   @id @default(uuid())
  productId    String
  dependencyId String
  versionRange String
  approved     Boolean  @default(false) // REQUIRED for dependency approval pipeline
  createdAt    DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
}

/////////////////////////
// SUBMISSIONS
/////////////////////////

model MarketplaceSubmission {
  id         String                      @id @default(uuid())
  productId  String
  versionId  String?
  status     MarketplaceSubmissionStatus
  reviewerId String?
  notes      String?
  createdAt  DateTime                    @default(now())

  product  MarketplaceProduct  @relation(fields: [productId], references: [id])
  version  MarketplaceVersion? @relation(fields: [versionId], references: [id])
  reviewer User?               @relation(fields: [reviewerId], references: [id])
}

/////////////////////////
// VERIFICATION
/////////////////////////

model MarketplaceVerification {
  id        String @id @default(uuid())
  productId String
  versionId String

  passed    Boolean
  issues    Json?
  createdAt DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
  version MarketplaceVersion @relation(fields: [versionId], references: [id])
}

/////////////////////////
// ANALYTICS
/////////////////////////

model MarketplaceAnalytics {
  id        String  @id @default(uuid())
  productId String
  versionId String?

  product MarketplaceProduct  @relation(fields: [productId], references: [id])
  version MarketplaceVersion? @relation(fields: [versionId], references: [id])

  eventType String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([versionId])
  @@index([eventType])
  @@index([createdAt])
}

/////////////////////////
// ACTIVE INSTANCES
/////////////////////////

model MarketplaceActiveInstance {
  id         String   @id @default(uuid())
  productId  String
  versionId  String?
  instanceId String
  userId     String?
  lastSeen   DateTime @default(now())
  createdAt  DateTime @default(now())
  meta       Json?

  @@index([productId])
  @@index([instanceId])
  @@index([lastSeen])
}

/////////////////////////
// CRASH LOGS
/////////////////////////

model MarketplaceCrash {
  id        String  @id @default(uuid())
  productId String
  versionId String?
  userId    String?

  message    String
  stackTrace String?  @db.Text
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([versionId])
  @@index([createdAt])
}

/////////////////////////
// PERFORMANCE METRICS
/////////////////////////

model MarketplacePerfMetric {
  id        String  @id @default(uuid())
  productId String
  versionId String?

  metric    String
  value     Float
  meta      Json?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([metric])
  @@index([createdAt])
}

/////////////////////////
// DAILY AGGREGATES
/////////////////////////

model MarketplaceAnalyticsAggregate {
  id        String   @id @default(uuid())
  productId String
  date      DateTime
  installs  Int      @default(0)
  active    Int      @default(0)
  crashes   Int      @default(0)
  createdAt DateTime @default(now())

  @@unique([productId, date])
  @@index([productId, date])
}

/////////////////////////
// WEBHOOK ENDPOINTS
/////////////////////////

model MarketplaceWebhookEndpoint {
  id        String   @id @default(uuid())
  vendorId  String
  url       String
  secret    String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([vendorId])
}

/////////////////////////
// BUILD LOGS
/////////////////////////

model MarketplaceBuildLog {
  id           String  @id @default(uuid())
  submissionId String?
  productId    String?
  versionId    String?

  level     String   @default("info")
  message   String
  meta      Json?
  step      String?
  createdAt DateTime @default(now())

  @@index([submissionId])
  @@index([productId])
  @@index([versionId])
  @@index([createdAt])
}

/////////////////////////
// WEBHOOK EVENTS
/////////////////////////

model MarketplaceWebhook {
  id        String   @id @default(uuid())
  event     String
  payload   Json
  createdAt DateTime @default(now())
}

////////////////////////////////////////////////////////////
// IP ACCESS RULES
////////////////////////////////////////////////////////////

model IpAccessRule {
  id          Int        @id @default(autoincrement())
  pattern     String
  type        IpRuleType
  description String?    @db.Text
  active      Boolean    @default(true)
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([pattern])
}

enum IpRuleType {
  ALLOW
  DENY
}

////////////////////////////////////////////////////////////
// SERVICES (Hosting Products Catalog)
////////////////////////////////////////////////////////////

model Service {
  id          Int     @id @default(autoincrement())
  code        String  @unique // internal reference (e.g. shared_hosting)
  name        String
  description String
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plans ServicePlan[]

  @@index([active])
}

model ServicePlan {
  id        Int     @id @default(autoincrement())
  serviceId Int
  name      String // Basic, Pro, Business
  summary   String?
  active    Boolean @default(true)
  position  Int     @default(0)

  service Service @relation(fields: [serviceId], references: [id])

  pricing  ServicePricing[]
  policies ServicePolicy[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([serviceId, name])
  @@index([serviceId])
}

enum BillingCycle {
  monthly
  quarterly
  semi_annually
  annually
}

model ServicePricing {
  id       Int          @id @default(autoincrement())
  planId   Int
  cycle    BillingCycle
  price    Decimal      @db.Decimal(10, 2)
  currency String       @default("USD")
  active   Boolean      @default(true)

  plan ServicePlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([planId, cycle])
  @@index([planId])
}

model ServicePolicy {
  id       Int     @id @default(autoincrement())
  planId   Int
  key      String
  value    Json
  enforced Boolean @default(true)

  plan ServicePlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())

  @@unique([planId, key])
}

model ServiceSnapshot {
  id        Int  @id @default(autoincrement())
  serviceId Int
  planId    Int?

  snapshot  Json
  orders    Order[]
  createdAt DateTime @default(now())

  @@index([serviceId])
}

/////////orders//////////
enum OrderStatus {
  pending
  active
  suspended
  terminated
  cancelled
}

model Order {
  id       String @id @default(uuid())
  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  snapshotId Int
  snapshot   ServiceSnapshot @relation(fields: [snapshotId], references: [id])

  status   OrderStatus @default(pending)
  invoices Invoice[]

  // NEW
  startedAt     DateTime?
  nextRenewalAt DateTime?
  suspendedAt   DateTime?
  terminatedAt  DateTime?
  cancelledAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([nextRenewalAt])
}

// ============================================================
// BILLING MODULE — SCHEMA ADDITIONS
// Append these models to your existing schema.prisma
// ============================================================

// ============================================================
// ENUMS
// ============================================================

enum InvoiceStatus {
  draft
  unpaid
  paid
  overdue
  cancelled
  refunded
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum TransactionType {
  payment
  refund
  adjustment
  credit
}

// ============================================================
// CLIENT BILLING PROFILE (FR-11)
// ============================================================

model BillingProfile {
  id       String @id @default(uuid())
  clientId String @unique
  client   User   @relation(fields: [clientId], references: [id])

  currency         String  @default("USD") // FR-12
  billingAddress   String?
  city             String?
  country          String?
  postalCode       String?
  taxId            String? // FR-07
  paymentMethodRef String? // FR-05 (gateway token ref)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  invoices Invoice[]
}

// ============================================================
// TAX RULES (FR-07)
// ============================================================

model TaxRule {
  id          Int     @id @default(autoincrement())
  name        String
  rate        Decimal @db.Decimal(5, 4) // e.g. 0.1700 = 17%
  country     String?
  region      String?
  serviceType String? // null = applies to all
  active      Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([country])
  @@index([active])
}

// ============================================================
// INVOICE (FR-01, FR-02, FR-06)
// ============================================================

model Invoice {
  id               String  @id @default(uuid())
  invoiceNumber    String  @unique // e.g. INV-2024-00001
  clientId         String
  billingProfileId String?

  orderId String? // linked order (nullable for manual)
  order   Order?  @relation(fields: [orderId], references: [id])

  billingProfile BillingProfile? @relation(fields: [billingProfileId], references: [id])
  client         User            @relation(fields: [clientId], references: [id])

  status InvoiceStatus @default(draft)

  currency       String  @default("USD") // FR-12
  subtotal       Decimal @db.Decimal(10, 2)
  taxAmount      Decimal @default(0) @db.Decimal(10, 2)
  discountAmount Decimal @default(0) @db.Decimal(10, 2)
  totalAmount    Decimal @db.Decimal(10, 2)
  amountPaid     Decimal @default(0) @db.Decimal(10, 2)
  amountDue      Decimal @db.Decimal(10, 2)

  dueDate     DateTime? // FR-14
  issuedAt    DateTime?
  paidAt      DateTime?
  cancelledAt DateTime?

  notes    String?
  metadata Json? // FR-10 extra context

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lineItems    InvoiceLineItem[]
  payments     Payment[]
  transactions BillingTransaction[]
  discounts    InvoiceDiscount[]

  @@index([clientId])
  @@index([status])
  @@index([dueDate])
  @@index([orderId])
  @@index([invoiceNumber])
}

// ============================================================
// INVOICE LINE ITEMS (FR-02)
// ============================================================

model InvoiceLineItem {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)

  taxRate   Decimal? @db.Decimal(5, 4)
  taxAmount Decimal? @db.Decimal(10, 2)

  serviceCode String? // snapshot reference
  planName    String?
  cycle       String?

  createdAt DateTime @default(now())

  @@index([invoiceId])
}

// ============================================================
// INVOICE DISCOUNTS / CREDITS (FR-08)
// ============================================================

model InvoiceDiscount {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  type        String // promo | credit | manual
  code        String? // promo code if applicable
  description String?
  amount      Decimal @db.Decimal(10, 2)
  isPercent   Boolean @default(false) // true = %, false = flat

  appliedAt DateTime @default(now())

  @@index([invoiceId])
}

// ============================================================
// PAYMENT (FR-04, FR-05)
// ============================================================

model Payment {
  id        String  @id @default(uuid())
  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  clientId String
  client   User   @relation(fields: [clientId], references: [id])

  amount   Decimal       @db.Decimal(10, 2)
  currency String        @default("USD")
  status   PaymentStatus @default(pending)

  // Gateway integration (FR-05)
  gateway         String? // stripe | paypal | manual
  gatewayRef      String? // external tx id
  gatewayResponse Json? // raw callback payload
  gatewayStatus   String?

  paidAt     DateTime?
  failedAt   DateTime?
  failReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refunds Refund[]

  @@index([invoiceId])
  @@index([clientId])
  @@index([status])
  @@index([gatewayRef])
}

// ============================================================
// REFUND (FR-09)
// ============================================================

model Refund {
  id        String  @id @default(uuid())
  paymentId String
  payment   Payment @relation(fields: [paymentId], references: [id])

  invoiceId String

  amount Decimal @db.Decimal(10, 2)
  reason String?
  notes  String?

  gateway         String?
  gatewayRef      String?
  gatewayResponse Json?

  processedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([paymentId])
  @@index([invoiceId])
}

// ============================================================
// BILLING TRANSACTION LOG (FR-10)
// ============================================================

model BillingTransaction {
  id        String   @id @default(uuid())
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])
  clientId  String

  type        TransactionType
  amount      Decimal         @db.Decimal(10, 2)
  currency    String          @default("USD")
  description String?
  meta        Json?

  createdAt DateTime @default(now())

  @@index([invoiceId])
  @@index([clientId])
  @@index([type])
  @@index([createdAt])
}
