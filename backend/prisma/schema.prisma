datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/////////////////////////////////////////
// USERS
/////////////////////////////////////////
model User {
  id            Int            @id @default(autoincrement())
  username      String?        @unique
  email         String         @unique
  password      String?
  role          String         @default("admin")
  provider      String         @default("local")
  googleId      String?        @unique
  displayName   String?
  avatarUrl     String?
  emailVerified Boolean        @default(false)
  lastLoginAt   DateTime?
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

/////////////////////////////////////////
// CLIENTS & SERVICES
/////////////////////////////////////////
model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientServices ClientService[]
  services       Service[]
  tickets        Ticket[]
}

model ClientService {
  id          String   @id @default(uuid())
  clientId    String
  serviceName String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Service {
  id        Int      @id @default(autoincrement())
  clientId  String
  plan      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Ticket {
  id        Int      @id @default(autoincrement())
  clientId  String
  subject   String
  message   String
  priority  String
  status    String   @default("open")
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

/////////////////////////////////////////
// EMAIL SYSTEM
/////////////////////////////////////////
model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  subject   String
  bodyHtml  String
  bodyText  String?
  language  String   @default("en")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs EmailJob[]
}

model EmailJob {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   Int?
  templateName String?
  toEmail      String
  toName       String?
  payload      Json?
  status       String   @default("queued")
  attempts     Int      @default(0)
  lastError    String?
  priority     String   @default("normal")
  provider     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@index([status])
}

model EmailEvent {
  id         Int      @id @default(autoincrement())
  jobId      String?
  eventType  String
  providerId String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([jobId])
}

/////////////////////////////////////////
// DOMAINS
/////////////////////////////////////////
model Domain {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  provider    String?
  status      String    @default("active")
  expiryDate  DateTime?
  nameservers String[]  @default([])
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deleted     Boolean   @default(false)
  deletedAt   DateTime?

  dnsRecords DNSRecord[]
  logs       DomainLog[]
}

model DNSRecord {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id])

  type       String
  name       String
  value      String
  ttl        Int      @default(3600)
  providerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DomainLog {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id])

  action    String
  message   String?
  meta      Json?
  createdAt DateTime @default(now())
}

/////////////////////////////////////////
// PROVIDER CONFIG
/////////////////////////////////////////
model ProviderConfig {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  key       String?
  secret    String?
  endpoint  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/////////////////////////////////////////
// TLD PRICING
/////////////////////////////////////////
model Tld {
  id            Int      @id @default(autoincrement())
  name          String   @unique
  registerPrice Int?
  renewPrice    Int?
  transferPrice Int?
  markupPercent Int?
  providerData  Json?
  lastSynced    DateTime?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/////////////////////////////////////////
// PLUGIN REGISTRY (NEW)
/////////////////////////////////////////
model Plugin {
  id        String   @id
  name      String
  version   String
  folder    String
  enabled   Boolean  @default(true)
  installedAt DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  settings PluginSetting[]
}

model PluginSetting {
  id        Int     @id @default(autoincrement())
  pluginId  String
  key       String
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plugin Plugin @relation(fields: [pluginId], references: [id])
  @@index([pluginId])
}


