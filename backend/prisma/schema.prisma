model ServicePlan {
  id                   String                     @id @default(uuid())
  serviceId            String
  name                 String
  summary              String?
  description          String?
  paymentType          String                     @default("regular")
  minimumBillingCycles Int                        @default(1)
  maximumBillingCycles Int?
  allowAutoSetup       Boolean                    @default(true)
  customizeOption      String                     @default("none")
