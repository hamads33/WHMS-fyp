// merged schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/////////////////////////////////////////
// USERS (Single Identity for ALL roles)
/////////////////////////////////////////
model User {
  id              String   @id @default(uuid())
  email           String   @unique
  passwordHash    String

  emailVerified   Boolean  @default(false)

  mfaEnabled      Boolean  @default(false)
  mfaSecret       String?
  mfaBackupCodes  String[] @default([])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // RBAC
  roles UserRole[]

  // Sessions (normal + impersonation sessions)
  sessions Session[]

  // API Keys
  apiKeys ApiKey[]

  // Login Attempts
  loginLogs LoginLog[]

  // Trusted devices, email tokens, audit logs
  trustedDevices TrustedDevice[]
  emailTokens    EmailToken[]
  auditLogs      AuditLog[]            // AuditLog now references user as String

  // Impersonation relations (both sides)
  impersonationsStarted  Impersonation[] @relation("Impersonator")
  impersonationsReceived Impersonation[] @relation("Impersonated")

  // Portal Profiles
  clientProfile    ClientProfile?
  adminProfile     AdminProfile?
  resellerProfile  ResellerProfile?
  developerProfile DeveloperProfile?

  // Marketplace Relations (converted to string userId)
  marketplaceReviews        MarketplaceReview[]
  marketplaceSubmissions    MarketplaceSubmission[]
  marketplaceSeller         MarketplaceSeller?       // 1-to-1 seller profile
  marketplacePurchases      MarketplacePurchase[]    // user purchases

  // Legacy / other
  refreshTokens RefreshToken[]   // keep existing RefreshToken model but userId is String now
}

/////////////////////////////////////////////////////////
// ROLE SYSTEM (Modular RBAC)
/////////////////////////////////////////////////////////
model Role {
  id          String  @id @default(uuid())
  name        String  @unique
  description String?

  // Relations
  permissions RolePermission[]
  userRoles   UserRole[]
}

model Permission {
  id          String           @id @default(uuid())
  key         String           @unique
  description String?
  rolePerms   RolePermission[]
}

model RolePermission {
  id           String     @id @default(uuid())
  role         Role       @relation(fields: [roleId], references: [id])
  roleId       String
  permission   Permission @relation(fields: [permissionId], references: [id])
  permissionId String

  @@unique([roleId, permissionId])
}

model UserRole {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String
  role   Role   @relation(fields: [roleId], references: [id])
  roleId String
    @@unique([userId, roleId]) // ADD THIS
}

/////////////////////////////////////////////////////////
// SESSIONS
/////////////////////////////////////////////////////////
model Session {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String

  token     String   @unique
  userAgent String?
  ip        String?
  createdAt DateTime @default(now())
  expiresAt DateTime

  // Impersonation support
  isImpersonation     Boolean @default(false)
  impersonatorId      String?
  impersonationReason String?
}

/////////////////////////////////////////////////////////
// TRUSTED DEVICES
/////////////////////////////////////////////////////////
model TrustedDevice {
  id         String   @id @default(uuid())
  user       User     @relation(fields: [userId], references: [id])
  userId     String
  deviceId   String   @unique
  userAgent  String?
  ip         String?
  name       String?
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @updatedAt
  expiresAt  DateTime
  revoked    Boolean  @default(false)
}

/////////////////////////////////////////////////////////
// API KEYS (Plugin Devs, Resellers, Integrations)
/////////////////////////////////////////////////////////
model ApiKey {
  id        String        @id @default(uuid())
  user      User          @relation(fields: [userId], references: [id])
  userId    String
  name      String
  keyHash   String
  createdAt DateTime      @default(now())
  revoked   Boolean       @default(false)
  expiresAt DateTime?
  scopes    ApiKeyScope[]
}

model ApiKeyScope {
  id       String @id @default(uuid())
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id])
  apiKeyId String
  scope    String
}

/////////////////////////////////////////////////////////
// LOGIN LOGS (Security/Audit)
/////////////////////////////////////////////////////////
model LoginLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  userEmail String?
  success   Boolean
  ip        String?
  userAgent String?
  reason    String?
  createdAt DateTime @default(now())
}

/////////////////////////////////////////////////////////
// USER PROFILES (Portal-specific metadata)
/////////////////////////////////////////////////////////

// CLIENT AREA ACCOUNT
model ClientProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  company String?
  phone   String?
  address String?
  country String?
  city    String?
  postal  String?
}

// ADMIN PORTAL STAFF ACCOUNT
model AdminProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  department      String?
  staffTitle      String?
  restrictionJson Json? // JSON for module-level restrictions, IP rules, schedules
}

// WHOLESALE / RESELLER PORTAL
model ResellerProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  resellerCode String  @unique
  company      String?
  phone        String?
  address      String?
}

// MARKETPLACE / PLUGIN DEVELOPER ACCOUNT
model DeveloperProfile {
  id     String @id @default(uuid())
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique

  displayName  String?
  website      String?
  github       String?
  payoutsEmail String?
}

/////////////////////////////////////////////////////////
// IMPERSONATION RECORD (optional extra)
/////////////////////////////////////////////////////////
model Impersonation {
  id             String    @id @default(uuid())
  adminId        String
  admin          User?     @relation("Impersonator", fields: [adminId], references: [id])
  impersonatedId String
  impersonated   User?     @relation("Impersonated", fields: [impersonatedId], references: [id])
  startedAt      DateTime  @default(now())
  endedAt        DateTime?
  sessionToken   String    @unique
  reason         String?
}

/////////////////////////////////////////////////////////
// EMAIL TOKENS (verification / password reset)
/////////////////////////////////////////////////////////
model EmailToken {
  id        String   @id @default(uuid())
  user      User     @relation(fields: [userId], references: [id])
  userId    String
  tokenHash String
  type      String // "verify_email" | "password_reset"
  createdAt DateTime @default(now())
  expiresAt DateTime
  used      Boolean  @default(false)
}

/////////////////////////////////////////////////////////
// AUDIT LOGS
/////////////////////////////////////////////////////////
// Using the richer AuditLog shape from auth module, keeping compatibility
model AuditLog {
  id        String   @id @default(uuid())
  user      User?    @relation(fields: [userId], references: [id])
  userId    String?
  action    String
  entity    String?
  entityId  String?
  ip        String?
  userAgent String?
  data      Json?
  createdAt DateTime @default(now())
}

/////////////////////////////////////////////////////////
// WEBHOOKS
/////////////////////////////////////////////////////////
model Webhook {
  id         String   @id @default(cuid())
  name       String   @unique
  url        String
  secret     String
  events     String[] // e.g. ["login.success","user.register"]
  active     Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  logs       WebhookLog[]
}

model WebhookLog {
  id          String   @id @default(cuid())
  webhookId   String
  event       String
  payload     Json
  status      String   // queued | success | failed
  httpStatus  Int?
  attempts    Int      @default(0)
  lastError   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  webhook Webhook @relation(fields: [webhookId], references: [id])
}

/////////////////////////////////////////////////////////
// KEEP/ADJUSTED MODELS FROM YOUR ORIGINAL SCHEMA
/////////////////////////////////////////////////////////

/////////////////////////////////////////
// RefreshToken (kept but userId changed to String)
/////////////////////////////////////////
model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    String
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

/////////////////////////////////////////
// CLIENTS & SERVICES
/////////////////////////////////////////
model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  clientServices ClientService[]
  services       Service[]
  tickets        Ticket[]
}

model ClientService {
  id          String   @id @default(uuid())
  clientId    String
  serviceName String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Service {
  id        Int      @id @default(autoincrement())
  clientId  String
  plan      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Ticket {
  id        Int      @id @default(autoincrement())
  clientId  String
  subject   String
  message   String
  priority  String
  status    String   @default("open")
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

/////////////////////////////////////////
// EMAIL SYSTEM
/////////////////////////////////////////
model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  subject   String
  bodyHtml  String
  bodyText  String?
  language  String   @default("en")
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs EmailJob[]
}

model EmailJob {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   Int?
  templateName String?
  toEmail      String
  toName       String?
  payload      Json?
  status       String   @default("queued")
  attempts     Int      @default(0)
  lastError    String?
  priority     String   @default("normal")
  provider     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@index([status])
}

model EmailEvent {
  id         Int      @id @default(autoincrement())
  jobId      String?
  eventType  String
  providerId String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([jobId])
}

/////////////////////////////////////////
// DOMAINS
/////////////////////////////////////////
model Domain {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  provider    String?
  status      String    @default("active")
  expiryDate  DateTime?
  nameservers String[]  @default([])
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deleted     Boolean   @default(false)
  deletedAt   DateTime?

  dnsRecords DNSRecord[]
  logs       DomainLog[]
}

model DNSRecord {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id])

  type       String
  name       String
  value      String
  ttl        Int      @default(3600)
  providerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DomainLog {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id])

  action    String
  message   String?
  meta      Json?
  createdAt DateTime @default(now())
}

/////////////////////////////////////////
// PROVIDER CONFIG
/////////////////////////////////////////
model ProviderConfig {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  key       String?
  secret    String?
  endpoint  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/////////////////////////////////////////
// TLD PRICING
/////////////////////////////////////////
model Tld {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  registerPrice Int?
  renewPrice    Int?
  transferPrice Int?
  markupPercent Int?
  providerData  Json?
  lastSynced    DateTime?
  active        Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

/////////////////////////////////////////
// PLUGIN REGISTRY
/////////////////////////////////////////
model Plugin {
  id          String   @id @default(uuid())
  name        String
  version     String
  folder      String
  enabled     Boolean  @default(true)
  installedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  settings PluginSetting[]
}

model PluginSetting {
  id        Int      @id @default(autoincrement())
  pluginId  String
  key       String
  value     Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  plugin Plugin @relation(fields: [pluginId], references: [id])

  @@index([pluginId])
}

/////////////////////////////////////////
// AUTOMATION
/////////////////////////////////////////
model AutomationProfile {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  cron        String
  enabled     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  tasks       AutomationTask[]
  runs        AutomationRun[]
}

model AutomationTask {
  id         Int      @id @default(autoincrement())
  profileId  Int
  actionType String
  actionMeta Json?
  order      Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  runs    AutomationRun[]
}

model AutomationRun {
  id           Int       @id @default(autoincrement())
  profileId    Int
  taskId       Int?
  status       String
  result       Json?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime  @default(now())

  profile AutomationProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  task    AutomationTask?   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([profileId])
  @@index([taskId])
}

/////////////////////////////////////////
// Marketplace System (FR-M1 → FR-M11)
/////////////////////////////////////////

/////////////////////////
// Seller
/////////////////////////
model MarketplaceSeller {
  id              String   @id @default(uuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  storeName       String
  stripeAccountId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  products MarketplaceProduct[]
}

/////////////////////////
// Category
/////////////////////////
model MarketplaceCategory {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  icon      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products MarketplaceProduct[]
}

/////////////////////////
// Product
/////////////////////////
model MarketplaceProduct {
  id            String   @id @default(uuid())
  sellerId      String
  seller        MarketplaceSeller @relation(fields: [sellerId], references: [id])
  title         String
  slug          String   @unique
  shortDesc     String?
  longDesc      String?
  category      String?
  categoryId    String?
  tags          String[]  @default([])
  status        String     @default("draft")
  rejectReason  String?
  logo          String?
  screenshots   String[]   @default([])
  documentation String?
  ratingAvg     Float      @default(0)
  ratingCount   Int        @default(0)
  installCount  Int        @default(0)
  downloadCount Int        @default(0)
  lastUpdatedAt DateTime?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  approvedAt    DateTime?   @default(now())

  versions      MarketplaceVersion[]
  purchases     MarketplacePurchase[]
  categoryRel   MarketplaceCategory? @relation(fields: [categoryId], references: [id])
  reviews       MarketplaceReview[]
  dependencies  MarketplaceDependency[]
  submissions   MarketplaceSubmission[]
  verifications MarketplaceVerification[]
  analytics     MarketplaceAnalytics[]
}

/////////////////////////
// Version
/////////////////////////
model MarketplaceVersion {
  id            String   @id @default(uuid())
  productId     String
  product       MarketplaceProduct @relation(fields: [productId], references: [id])
  version       String
  manifestJson  Json
  archivePath   String
  changelog     String?
  priceCents    Int
  currency      String   @default("USD")
  createdAt     DateTime @default(now())

  purchases     MarketplacePurchase[]
  analytics     MarketplaceAnalytics[]
  submissions   MarketplaceSubmission[]
  verifications MarketplaceVerification[]
}

/////////////////////////
// Purchases / Licensing
/////////////////////////
model MarketplacePurchase {
  id              String   @id @default(uuid())
  userId          String
  productId       String
  versionId       String
  licenseKey      String   @unique
  subscribed      Boolean  @default(false)
  activationLimit Int      @default(1)
  expiresAt       DateTime?
  revoked         Boolean  @default(false)
  createdAt       DateTime @default(now())

  user     User               @relation(fields: [userId], references: [id])
  product  MarketplaceProduct @relation(fields: [productId], references: [id])
  version  MarketplaceVersion @relation(fields: [versionId], references: [id])
  activations MarketplaceLicenseActivation[]
}

model MarketplaceLicenseActivation {
  id        String   @id @default(uuid())
  licenseId String
  userAgent String?
  host      String?
  ip        String?
  createdAt DateTime @default(now())

  purchase MarketplacePurchase @relation(fields: [licenseId], references: [id])
}

/////////////////////////
// Reviews (FR-M10)
/////////////////////////
model MarketplaceReview {
  id        String   @id @default(uuid())
  productId String
  userId    String
  rating    Int
  stability Int?
  review    String?
  createdAt DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
  user    User               @relation(fields: [userId], references: [id])
}

/////////////////////////
// Dependencies (FR-M7)
/////////////////////////
model MarketplaceDependency {
  id           String   @id @default(uuid())
  productId    String
  dependencyId String
  versionRange String
  createdAt    DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
}

/////////////////////////
// Submissions (FR-M6)
/////////////////////////
model MarketplaceSubmission {
  id          String   @id @default(uuid())
  productId   String
  versionId   String?
  status      String
  reviewerId  String?
  notes       String?
  createdAt   DateTime @default(now())

  product MarketplaceProduct  @relation(fields: [productId], references: [id])
  version MarketplaceVersion? @relation(fields: [versionId], references: [id])
  reviewer User?              @relation(fields: [reviewerId], references: [id])
}

/////////////////////////
// Verification (FR-M8)
/////////////////////////
model MarketplaceVerification {
  id        String   @id @default(uuid())
  productId String
  versionId String
  passed    Boolean
  issues    Json?
  createdAt DateTime @default(now())

  product MarketplaceProduct @relation(fields: [productId], references: [id])
  version MarketplaceVersion @relation(fields: [versionId], references: [id])
}

/////////////////////////
// Analytics (FR-M9)
/////////////////////////
model MarketplaceAnalytics {
  id        String   @id @default(uuid())

  // RELATIONS (required by Product.analytics & Version.analytics)
  productId String
  product   MarketplaceProduct @relation(fields: [productId], references: [id])

  versionId String?
  version   MarketplaceVersion? @relation(fields: [versionId], references: [id])

  eventType String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([versionId])
  @@index([eventType])
  @@index([createdAt])
}

model MarketplaceActiveInstance {
  id         String   @id @default(uuid())
  productId  String
  versionId  String?
  instanceId String   // unique id for plugin instance (user+host)
  userId     String?
  lastSeen   DateTime @default(now())
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([instanceId])
  @@index([lastSeen])
}

model MarketplaceCrash {
  id         String   @id @default(uuid())
  productId  String
  versionId  String?
  userId     String?
  message    String
  stackTrace String?  @db.Text
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([versionId])
  @@index([createdAt])
}

model MarketplacePerfMetric {
  id         String   @id @default(uuid())
  productId  String
  versionId  String?
  metric     String   // e.g. "action_latency_ms", "memory_mb", "cpu_percent"
  value      Float
  meta       Json?
  createdAt  DateTime @default(now())

  @@index([productId])
  @@index([metric])
  @@index([createdAt])
}

model MarketplaceAnalyticsAggregate {
  id         String   @id @default(uuid())
  productId  String
  date       DateTime // date bucket (UTC midnight)
  installs   Int      @default(0)
  active     Int      @default(0)
  crashes    Int      @default(0)
  createdAt  DateTime @default(now())

  @@unique([productId, date])
  @@index([productId, date])
}

model MarketplaceWebhookEndpoint {
  id        String   @id @default(uuid())
  vendorId  String
  url       String
  secret    String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())

  @@index([vendorId])
}

model MarketplaceBuildLog {
  id            String   @id @default(uuid())
  submissionId  String?              // optional: attached to a submission
  productId     String?              // optional: which product version/build
  versionId     String?              // optional: version id
  level         String   @default("info") // info | warn | error | debug
  message       String
  meta          Json?
  step          String?              // e.g. "upload", "validate", "sign", "installDeps", "verify"
  createdAt     DateTime @default(now())

  // indexes for fast lookup
  @@index([submissionId])
  @@index([productId])
  @@index([versionId])
  @@index([createdAt])
}

model MarketplaceWebhook {
  id        String   @id @default(uuid())
  event     String
  payload   Json
  createdAt DateTime @default(now())
}

/////////////////////////////////////////////////////////
// Marketplace other models done
/////////////////////////////////////////////////////////

/// schema.prisma (append)
model IpAccessRule {
  id            Int       @id @default(autoincrement())
  pattern       String    // "1.2.3.4", "1.2.3.0/24", "1.2.*.*"
  type          IpRuleType
  description   String?   @db.Text
  active        Boolean   @default(true)
  createdById   String?   // admin user id who created the rule (converted to String)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([pattern])
}

enum IpRuleType {
  ALLOW
  DENY
}
