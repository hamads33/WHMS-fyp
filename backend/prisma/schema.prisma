enum BroadcastType {
  NOTIFICATION
  DOCUMENT
}

enum BroadcastTarget {
  ALL
  CLIENTS
  STAFF
  DEVELOPERS
  SPECIFIC_USERS
}

enum BroadcastSeverity {
  INFO
  WARNING
  CRITICAL
}

enum EngagementAction {
  VIEW
  DISMISS
  DOWNLOAD
}

model Broadcast {
  id               Int               @id @default(autoincrement())
  type             BroadcastType
  title            String
  content          String?
  fileKey          String?
  fileOriginalName String?
  fileMimeType     String?
  fileSize         Int?
  targetAudience   BroadcastTarget   @default(ALL)
  targetUserIds    Json?
  severity         BroadcastSeverity @default(INFO)
  isDismissible    Boolean           @default(true)
  publishAt        DateTime?
  expiresAt        DateTime?
  isActive         Boolean           @default(true)
  createdById      String
  createdBy        User              @relation("BroadcastCreator", fields: [createdById], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  dismissals       BroadcastDismissal[]
  engagements      BroadcastEngagement[]

  @@index([type])
  @@index([targetAudience])
  @@index([publishAt])
  @@index([expiresAt])
  @@index([isActive])
}

model BroadcastDismissal {
  id          Int       @id @default(autoincrement())
  broadcastId Int
  broadcast   Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation("BroadcastDismissalUser", fields: [userId], references: [id], onDelete: Cascade)
  dismissedAt DateTime  @default(now())

  @@unique([broadcastId, userId])
  @@index([userId])
}

model BroadcastEngagement {
  id          Int              @id @default(autoincrement())
  broadcastId Int
  broadcast   Broadcast        @relation(fields: [broadcastId], references: [id], onDelete: Cascade)
  userId      String
  user        User             @relation("BroadcastEngagementUser", fields: [userId], references: [id], onDelete: Cascade)
  action      EngagementAction
  createdAt   DateTime         @default(now())

  @@index([broadcastId])
  @@index([userId])
  @@index([action])
}
