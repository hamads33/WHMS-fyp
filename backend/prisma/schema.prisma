datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id            Int            @id @default(autoincrement())
  username      String?        @unique
  email         String         @unique
  password      String? // nullable for OAuth users
  role          String         @default("admin") // admin, support, reseller, client
  provider      String         @default("local") // "local" | "google" | "github" etc.
  googleId      String?        @unique // Google "sub"
  displayName   String?
  avatarUrl     String?
  emailVerified Boolean        @default(false)
  lastLoginAt   DateTime?
  refreshTokens RefreshToken[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

model RefreshToken {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  userId    Int
  revoked   Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model Client {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // keeps references to legacy client-typed services (previously ClientService[] named `services`)
  clientServices ClientService[]

  // new Service and Ticket relations (these refer to the Service and Ticket models)
  services Service[]
  tickets  Ticket[]
}

model ClientService {
  id          String   @id @default(uuid())
  clientId    String
  serviceName String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model EmailTemplate {
  id        Int      @id @default(autoincrement())
  name      String   @unique // e.g. "invoice.created"
  subject   String
  bodyHtml  String
  bodyText  String?
  language  String   @default("en") // e.g. "en", "es"
  isDefault Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  jobs EmailJob[]
}

model EmailJob {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId   Int?
  templateName String?
  toEmail      String
  toName       String?
  payload      Json?
  status       String   @default("queued") // queued, processing, sent, failed
  attempts     Int      @default(0)
  lastError    String?
  priority     String   @default("normal") // high/normal/low
  provider     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  template EmailTemplate? @relation(fields: [templateId], references: [id])

  @@index([templateId])
  @@index([status])
}

model EmailEvent {
  id         Int      @id @default(autoincrement())
  jobId      String?
  eventType  String // queued, sent, delivered, bounce, opened, failed
  providerId String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([jobId])
}

model Service {
  id        Int      @id @default(autoincrement())
  clientId  String
  plan      String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model Ticket {
  id        Int      @id @default(autoincrement())
  clientId  String
  subject   String
  message   String
  priority  String
  status    String   @default("open")
  createdAt DateTime @default(now())

  client Client @relation(fields: [clientId], references: [id])

  @@index([clientId])
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  meta      Json?
  createdAt DateTime @default(now())

  @@index([userId])
}

model Domain {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  provider    String?
  status      String    @default("active")
  expiryDate  DateTime?
  nameservers String[]  @default([])
  metadata    Json?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deleted     Boolean   @default(false)
  deletedAt   DateTime?

  // 🔥 Required back-relations
  dnsRecords DNSRecord[]
  logs       DomainLog[]
}

model DNSRecord {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id])

  type       String
  name       String
  value      String
  ttl        Int      @default(3600)
  providerId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model DomainLog {
  id       Int    @id @default(autoincrement())
  domainId Int
  domain   Domain @relation(fields: [domainId], references: [id])

  action    String
  message   String?
  meta      Json?
  createdAt DateTime @default(now())
}

model ProviderConfig {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  key       String?
  secret    String?
  endpoint  String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


model Tld {
  id           Int      @id @default(autoincrement())
  name         String   @unique
  registerPrice Int?     // stored in cents
  renewPrice    Int?
  transferPrice Int?
  markupPercent Int?     // optional default markup percent
  providerData  Json?    // raw porkbun response for this TLD
  lastSynced    DateTime?
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Profile {
  id          Int       @id @default(autoincrement())
  name        String
  description String?
  cron        String    // cron expression
  timezone    String    @default("UTC")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tasks       Task[]
}

model Task {
  id             Int      @id @default(autoincrement())
  profile        Profile  @relation(fields: [profileId], references: [id])
  profileId      Int
  name           String
  actionId       String
  config         Json
  order          Int      @default(0)
  isActive       Boolean  @default(true)
  retries        Int      @default(3)
  backoffMs      Int      @default(2000)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  // ❗ NO onDelete HERE (this is the parent side)
  runs           Run[]
}

model Run {
  id             Int      @id @default(autoincrement())

  // ❗ Child side holds FK → cascade goes here
  taskId         Int
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  startedAt      DateTime @default(now())
  finishedAt     DateTime?
  status         String
  attempt        Int      @default(1)
  log            Json?
  errorMessage   String?
  createdAt      DateTime @default(now())
}


model Audit {
  id        Int      @id @default(autoincrement())
  actor     String?  // optional: user/system
  action    String
  payload   Json?
  createdAt DateTime @default(now())
}
